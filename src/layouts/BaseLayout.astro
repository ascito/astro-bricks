---
/**
 * BaseLayout — Layout racine des sites Factory.
 *
 * Compose en un seul endroit :
 *  - <html lang> + skip link a11y
 *  - SeoHead complet (depuis siteConfig + props page)
 *  - JsonLdOrganization (depuis siteConfig)
 *  - JsonLdBreadcrumb (si breadcrumbs fourni)
 *  - Header business (depuis siteConfig.nav)
 *  - Slot principal
 *  - Footer business (depuis siteConfig)
 *  - BackToTop (avec palette siteConfig.palette.primary)
 *  - ClientRouter Astro View Transitions (optionnel)
 *
 * Le BaseLayout fait toute l'agrégation entre siteConfig et les composants
 * sous-jacents — les sites n'ont qu'à passer leur config et les props de page.
 *
 * Usage typique :
 * ```astro
 * ---
 * import BaseLayout from 'astro-bricks/layouts/BaseLayout.astro';
 * import siteConfig from '~/site.config';
 * ---
 *
 * <BaseLayout
 *   siteConfig={siteConfig}
 *   title="Choisir une station météo connectée"
 *   description="Guide d'achat 2026..."
 *   ogType="article"
 *   breadcrumbs={[
 *     { label: 'Accueil', href: '/' },
 *     { label: 'Guides', href: '/guide' },
 *     { label: 'Choisir' },
 *   ]}
 * >
 *   <h1>Contenu de la page</h1>
 * </BaseLayout>
 * ```
 */
import type { ResolvedSiteConfig } from '../config/types';
import SeoHead from '../bricks/seo/SeoHead.astro';
import JsonLdOrganization from '../bricks/seo/JsonLdOrganization.astro';
import JsonLdBreadcrumb from '../bricks/seo/JsonLdBreadcrumb.astro';
import Header from '../bricks/nav/Header.astro';
import Footer from '../bricks/nav/Footer.astro';
import BackToTop from '../bricks/business/BackToTop.astro';

interface BreadcrumbItem {
  label: string;
  href?: string;
}

interface Props {
  /** Configuration du site (depuis site.config.ts). */
  siteConfig: ResolvedSiteConfig;

  // ─── Page metadata ───
  title: string;
  description: string;
  /** URL canonique. Si absent, calculé depuis siteUrl + pathname. */
  canonical?: string;
  noindex?: boolean;
  nofollow?: boolean;

  // ─── Open Graph page ───
  ogImage?: string;
  ogImageAlt?: string;
  ogType?: 'website' | 'article' | 'product';
  publishedTime?: string;
  modifiedTime?: string;
  author?: string;

  // ─── Breadcrumbs ───
  /** Fil d'ariane pour JSON-LD BreadcrumbList. Le rendu visuel est dans la page. */
  breadcrumbs?: BreadcrumbItem[];

  // ─── Brand / Logo (override siteConfig.brand) ───
  /** Path du logo affiché dans le Header. Défaut: `/images/logo.svg`. */
  logoSrc?: string;
  /** Hauteur du logo. Défaut: 40. */
  logoHeight?: number;

  // ─── Header (override siteConfig.nav) ───
  /** CTA mis en avant dans le Header (optionnel). */
  headerCta?: { href: string; label: string };

  // ─── View Transitions ───
  /** Active Astro <ClientRouter /> pour les View Transitions natives. Défaut: false. */
  viewTransitions?: boolean;

  // ─── Analytics ───
  /** Token Cloudflare Insights (si défini, injecte le beacon). */
  cfBeaconToken?: string;
}

const {
  siteConfig,
  title,
  description,
  canonical,
  noindex = false,
  nofollow = false,
  ogImage,
  ogImageAlt,
  ogType = 'website',
  publishedTime,
  modifiedTime,
  author,
  breadcrumbs,
  logoSrc = '/images/logo.svg',
  logoHeight = 40,
  headerCta,
  viewTransitions = false,
  cfBeaconToken,
} = Astro.props;

// Canonical : prop > calculé depuis siteConfig + pathname
const computedCanonical = canonical
  || `${siteConfig.siteUrl}${Astro.url.pathname.replace(/\/$/, '') || '/'}`;

// Locale BCP-47 → lang HTML
const htmlLang = siteConfig.locale.split('-')[0]; // 'fr-FR' → 'fr'

// Locale OpenGraph (underscore)
const ogLocale = siteConfig.locale.replace('-', '_');

// Palette pour les composants
const primaryColor = siteConfig.palette.primary;
const accentColor = siteConfig.palette.accent;

// Bouton BackToTop : palette primary
const backToTopClass = `bg-${primaryColor} hover:bg-${accentColor} text-white focus-visible:outline-${primaryColor}`;

// Header : items + brand
const headerBrand = {
  logoSrc,
  label: siteConfig.brand,
  href: '/',
  logoHeight,
};

const headerPalette = {
  activeText: `text-${primaryColor}`,
  hoverText: `hover:text-${primaryColor}`,
  hoverBg: 'hover:bg-slate-50',
  ctaBg: `bg-${primaryColor}`,
  ctaHoverBg: `hover:bg-${accentColor}`,
};

// Footer
const footerProps = {
  brandName: siteConfig.brand,
  tagline: siteConfig.tagline,
  contactEmail: siteConfig.contactEmail,
  foundingYear: siteConfig.foundingYear,
  columns: siteConfig.footer?.columns,
};

// sameAs réseaux sociaux pour Organization
const sameAs = Object.values(siteConfig.social).filter((s): s is string => typeof s === 'string' && s.length > 0);

// Charger ClientRouter dynamiquement (sinon import inutile si désactivé)
const ClientRouter = viewTransitions
  ? (await import('astro:transitions')).ClientRouter
  : null;
---

<!doctype html>
<html lang={htmlLang}>
  <head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <meta name="generator" content={Astro.generator} />

    <SeoHead
      title={title}
      description={description}
      canonical={computedCanonical}
      siteName={siteConfig.brand}
      ogImage={ogImage}
      ogImageAlt={ogImageAlt}
      ogType={ogType}
      author={author ?? siteConfig.brand}
      publishedTime={publishedTime}
      modifiedTime={modifiedTime}
      noindex={noindex}
      nofollow={nofollow}
      locale={ogLocale}
    />

    <JsonLdOrganization
      siteUrl={siteConfig.siteUrl}
      siteName={siteConfig.brand}
      description={siteConfig.tagline}
      contactEmail={siteConfig.contactEmail}
      inLanguage={siteConfig.locale}
      sameAs={sameAs}
    />

    {breadcrumbs && breadcrumbs.length > 0 && (
      <JsonLdBreadcrumb items={breadcrumbs.map(b => ({ label: b.label, url: b.href ?? '#' }))} siteUrl={siteConfig.siteUrl} />
    )}

    {ClientRouter && <ClientRouter />}

    <slot name="head" />
  </head>
  <body class="flex min-h-screen flex-col bg-white text-slate-800 antialiased">
    <a
      href="#main-content"
      class="sr-only focus:not-sr-only focus:absolute focus:top-4 focus:left-4 focus:z-[100] focus:bg-white focus:px-4 focus:py-2 focus:rounded-lg focus:shadow-lg focus:ring-2"
    >
      Aller au contenu principal
    </a>

    <Header
      brand={headerBrand}
      items={siteConfig.nav.items}
      cta={headerCta}
      palette={headerPalette}
    />

    <main id="main-content" role="main" class="flex-1">
      <slot />
    </main>

    <Footer {...footerProps}>
      <Fragment slot="col-2"><slot name="footer-col-2" /></Fragment>
      <Fragment slot="col-3"><slot name="footer-col-3" /></Fragment>
      <Fragment slot="col-4"><slot name="footer-col-4" /></Fragment>
      <Fragment slot="legal"><slot name="footer-legal" /></Fragment>
    </Footer>

    <BackToTop class={backToTopClass} />

    {cfBeaconToken && (
      <script
        defer
        src="https://static.cloudflareinsights.com/beacon.min.js"
        data-cf-beacon={`{"token": "${cfBeaconToken}"}`}
      />
    )}
  </body>
</html>
