---
/**
 * BrickNode — rend récursivement une brique résolue.
 *
 * Pattern :
 *  1. On récupère le composant Astro depuis le BRICK_REGISTRY
 *  2. On lui passe les inputs comme props
 *  3. Pour chaque enfant des slots, on rend <Astro.self node={child} slot={slotName} />.
 *     Le `slot=` directement sur l'enfant remplace l'ancien pattern
 *     `<Fragment slot={dynamic}>` qui cassait à la minification prod.
 *  4. Si la brique n'a aucun slot, on appelle le composant sans children
 *     (route minimale pour les briques feuilles, majoritaires).
 */
import type { ResolvedBrick } from './engine/types';
import { BRICK_REGISTRY } from './engine/registry';
import Fallback from './bricks/Fallback.astro';
// Récursion via import explicite de la brique sur elle-même : plus robuste
// qu'`Astro.self`, qui perdait la variable de boucle (`entry is not defined`)
// au build minifié quand on lui passe un `slot=` dynamique.
import BrickNode from './BrickNode.astro';

interface Props {
  node: ResolvedBrick;
}

const { node } = Astro.props;
const Component = (BRICK_REGISTRY[node.brick] as any) ?? Fallback;
const slotNames = Object.keys(node.children);
const hasSlots = slotNames.length > 0;
const isFallback = Component === Fallback;

// Vocabulaire complet des slots de la lib. On rend chaque slot avec un nom
// LITTÉRAL statique (cf. bloc template) : un `slot=` dynamique issu d'une
// variable de boucle casse au build minifié (`entry is not defined`), car
// Astro extrait les enfants slottés dans des fonctions séparées par nom.
const c = node.children;
---

{!hasSlots && isFallback && (
  <Component {...node.inputs} _brickId={node.id} _brickType={node.brick}>
    <span>Brique inconnue : <code>{node.brick}</code></span>
  </Component>
)}

{!hasSlots && !isFallback && (
  <Component {...node.inputs} _brickId={node.id} _brickType={node.brick} />
)}

{hasSlots && (
  <Component {...node.inputs} _brickId={node.id} _brickType={node.brick}>
    {c.children?.map((child) => <BrickNode node={child} slot="children" />)}
    {c.body?.map((child) => <BrickNode node={child} slot="body" />)}
    {c.header?.map((child) => <BrickNode node={child} slot="header" />)}
    {c.footer?.map((child) => <BrickNode node={child} slot="footer" />)}
    {c.actions?.map((child) => <BrickNode node={child} slot="actions" />)}
    {c.sidebar?.map((child) => <BrickNode node={child} slot="sidebar" />)}
    {c.trigger?.map((child) => <BrickNode node={child} slot="trigger" />)}
    {c.legal?.map((child) => <BrickNode node={child} slot="legal" />)}
  </Component>
)}
