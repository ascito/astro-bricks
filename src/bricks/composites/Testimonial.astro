---
/**
 * testimonial — Témoignage client avec avatar (catalog composite)
 * Schema : quote (req), author (req: name, title?, company?, avatar?, initials?),
 *          rating?, date?, variant, size, align, showQuotes, avatarSize, avatarPosition, background, borderColor
 */
interface Author {
  name: string;
  title?: string;
  company?: string;
  avatar?: string;
  initials?: string;
}
interface Props {
  quote: string;
  author: Author;
  rating?: number;
  date?: string;
  variant?: 'default' | 'card' | 'minimal' | 'featured';
  size?: 'sm' | 'md' | 'lg';
  align?: 'left' | 'center' | 'right';
  showQuotes?: boolean;
  avatarSize?: 'sm' | 'md' | 'lg' | 'xl';
  avatarPosition?: 'top' | 'left' | 'inline';
  background?: 'none' | 'light' | 'dark' | 'primary' | 'gradient';
  borderColor?: 'none' | 'gray' | 'primary';
  className?: string;
  id?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  quote,
  author,
  rating,
  date,
  variant = 'default',
  size = 'md',
  align = 'left',
  showQuotes = true,
  avatarSize = 'md',
  avatarPosition = 'inline',
  background = 'none',
  borderColor = 'none',
  className = '',
  id,
} = Astro.props;

const wrapperClass = {
  default: 'p-5',
  card: 'p-6 rounded-2xl shadow-sm',
  minimal: 'p-3',
  featured: 'p-8 rounded-2xl shadow-md',
}[variant];

const bgClass = {
  none: 'bg-transparent',
  light: 'bg-slate-50',
  dark: 'bg-slate-900 text-white',
  primary: 'bg-indigo-50',
  gradient: 'bg-gradient-to-br from-indigo-50 to-rose-50',
}[background];

const borderClass = {
  none: '',
  gray: 'border border-slate-200',
  primary: 'border-2 border-indigo-300',
}[borderColor];

const sizeClass = { sm: 'text-sm', md: 'text-base', lg: 'text-lg' }[size];
const alignClass = { left: 'text-left', center: 'text-center', right: 'text-right' }[align];

const avatarPx = { sm: 32, md: 44, lg: 56, xl: 72 }[avatarSize];

const AvatarBlock = () => null; // placeholder pour clarté

const initials = author.initials || author.name.split(' ').slice(0, 2).map((n) => n[0]).join('').toUpperCase();
---
<figure id={id} class={`${wrapperClass} ${bgClass} ${borderClass} ${alignClass} ${className}`}>
  {rating !== undefined && (
    <div class="mb-3 inline-flex" aria-label={`Note ${rating}/5`}>
      {Array.from({ length: 5 }, (_, i) => (
        <svg viewBox="0 0 24 24" width="16" height="16" style={`fill: ${i < rating ? '#facc15' : '#cbd5e1'}; margin-right: 1px;`}>
          <path d="M12 2l3.09 6.26L22 9.27l-5 4.87 1.18 6.88L12 17.77l-6.18 3.25L7 14.14 2 9.27l6.91-1.01z" />
        </svg>
      ))}
    </div>
  )}

  <blockquote class={`${sizeClass} leading-relaxed`}>
    {showQuotes && <span class="text-3xl leading-none text-indigo-300 font-serif select-none">"</span>}
    <span>{quote}</span>
    {showQuotes && <span class="text-3xl leading-none text-indigo-300 font-serif select-none">"</span>}
  </blockquote>

  <figcaption class={`mt-4 flex items-center gap-3 ${align === 'center' ? 'justify-center' : align === 'right' ? 'justify-end' : ''} ${avatarPosition === 'top' ? 'flex-col gap-2' : ''}`}>
    {(author.avatar || initials) && (
      author.avatar
        ? <img src={author.avatar} alt={author.name} width={avatarPx} height={avatarPx} class="rounded-full object-cover" style={`width:${avatarPx}px; height:${avatarPx}px;`} />
        : <span class="rounded-full bg-indigo-100 text-indigo-700 font-semibold flex items-center justify-center" style={`width:${avatarPx}px; height:${avatarPx}px; font-size:${avatarPx * 0.4}px;`}>{initials}</span>
    )}
    <div class={avatarPosition === 'top' ? 'text-center' : ''}>
      <div class="font-semibold not-italic">{author.name}</div>
      {(author.title || author.company) && (
        <div class={`text-xs ${background === 'dark' ? 'text-slate-300' : 'text-slate-500'}`}>
          {author.title}{author.title && author.company && ' · '}{author.company}
        </div>
      )}
      {date && (
        <div class={`text-xs mt-0.5 ${background === 'dark' ? 'text-slate-400' : 'text-slate-400'}`}>{date}</div>
      )}
    </div>
  </figcaption>
</figure>
