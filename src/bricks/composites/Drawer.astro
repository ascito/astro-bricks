---
/**
 * drawer — Panneau latéral coulissant.
 *
 * Schema catalog : {
 *   id?, position?, size?, title?, trigger?, open?, overlay?, closeOnOverlay?,
 *   closeOnEscape?, showClose?, persistent?, className?
 * }
 *
 * Fonctionnement : élément natif `<dialog>` ancré sur un bord via CSS (`position`).
 * Un déclencheur (`trigger` = sélecteur CSS, ou `[data-drawer-open="id"]`, ou
 * `a[href="#id"]`) appelle `showModal()`. Le backdrop natif sert d'overlay quand
 * `overlay` est vrai. `closeOnOverlay` ferme au clic sur le backdrop (sauf si
 * `persistent`), `closeOnEscape` gère/annule le `cancel` natif. Le panneau glisse
 * depuis le bord (`translate`). Script suivant le pattern TableOfContents (ré-init
 * `astro:page-load` + guard `dataset.initialized`).
 *
 * Théming : `--bricks-color-surface`, `--bricks-color-border`, `--bricks-color-text`
 * avec fallbacks.
 */
interface Props {
  /** ID HTML (requis pour trigger). */
  id?: string;
  /** Position du drawer. Défaut : "left". */
  position?: 'left' | 'right' | 'top' | 'bottom';
  /** Largeur/hauteur du drawer. Défaut : "md". */
  size?: 'sm' | 'md' | 'lg' | 'xl' | 'full';
  /** Titre du drawer (header). */
  title?: string;
  /** Sélecteur CSS du bouton déclencheur. */
  trigger?: string;
  /** État initial ouvert. Défaut : false. */
  open?: boolean;
  /** Afficher un overlay derrière. Défaut : true. */
  overlay?: boolean;
  /** Fermer au clic sur l'overlay. Défaut : true. */
  closeOnOverlay?: boolean;
  /** Fermer avec Escape. Défaut : true. */
  closeOnEscape?: boolean;
  /** Afficher le bouton fermer. Défaut : true. */
  showClose?: boolean;
  /** Drawer persistant (ne ferme pas au clic extérieur). Défaut : false. */
  persistent?: boolean;
  /** Override des classes du panneau. */
  className?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  id,
  position = 'left',
  size = 'md',
  title,
  trigger,
  open = false,
  overlay = true,
  closeOnOverlay = true,
  closeOnEscape = true,
  showClose = true,
  persistent = false,
  className = '',
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const drawerId = id || `drawer-${_brickId ?? Math.random().toString(36).slice(2, 8)}`;
const titleId = `${drawerId}-title`;
const horizontal = position === 'left' || position === 'right';

const sizeMap = horizontal
  ? { sm: 'w-72', md: 'w-80 sm:w-96', lg: 'w-[28rem]', xl: 'w-[34rem]', full: 'w-screen' }
  : { sm: 'h-40', md: 'h-64', lg: 'h-80', xl: 'h-96', full: 'h-screen' };
const sizeClass = sizeMap[size];

const anchorClass = {
  left: 'drawer-left',
  right: 'drawer-right',
  top: 'drawer-top',
  bottom: 'drawer-bottom',
}[position];
---

<dialog
  id={drawerId}
  data-drawer
  data-position={position}
  data-trigger={trigger}
  data-overlay={overlay ? 'true' : 'false'}
  data-close-overlay={closeOnOverlay ? 'true' : 'false'}
  data-close-escape={closeOnEscape ? 'true' : 'false'}
  data-persistent={persistent ? 'true' : 'false'}
  data-open-initial={open ? 'true' : 'false'}
  aria-labelledby={title ? titleId : undefined}
  class:list={[
    'drawer-dialog p-0',
    horizontal ? `h-screen max-h-screen ${sizeClass}` : `w-screen max-w-screen ${sizeClass}`,
    anchorClass,
    overlay ? 'drawer-has-overlay' : 'drawer-no-overlay',
    'border-[var(--bricks-color-border,#e2e8f0)]',
    'bg-[var(--bricks-color-surface,#ffffff)] text-[var(--bricks-color-text,#0f172a)] shadow-2xl',
    className,
  ]}
  {...rest}
>
  <div class="flex h-full flex-col">
    {(title || showClose) && (
      <header class="flex items-center justify-between gap-4 border-b border-[var(--bricks-color-border,#e2e8f0)] px-5 py-4">
        {title && (
          <h2 id={titleId} class="font-sans font-extrabold tracking-tight text-lg">
            {title}
          </h2>
        )}
        {showClose && (
          <button
            type="button"
            data-drawer-close
            aria-label="Fermer"
            class="ml-auto rounded text-2xl leading-none text-[var(--bricks-color-text-muted,#475569)] transition hover:text-[var(--bricks-color-text,#0f172a)] focus-visible:outline-2 focus-visible:outline-offset-2"
          >
            ×
          </button>
        )}
      </header>
    )}
    <div class="flex-1 overflow-y-auto px-5 py-4 text-[var(--bricks-color-text-muted,#475569)] [&_a]:text-[var(--bricks-color-accent,#2563eb)] [&_a]:underline">
      <slot name="children" />
      <slot />
    </div>
  </div>
</dialog>

<style>
  .drawer-dialog {
    margin: 0;
    max-width: none;
    border-style: solid;
    border-width: 0;
    transition: transform 0.3s ease;
  }
  .drawer-dialog:not([open]) { display: none; }

  .drawer-left   { inset: 0 auto 0 0; border-right-width: 1px; }
  .drawer-right  { inset: 0 0 0 auto; border-left-width: 1px; }
  .drawer-top    { inset: 0 0 auto 0; width: 100vw; max-width: 100vw; border-bottom-width: 1px; }
  .drawer-bottom { inset: auto 0 0 0; width: 100vw; max-width: 100vw; border-top-width: 1px; }

  /* Slide-in */
  .drawer-left[open]   { animation: drawer-slide-left 0.3s ease; }
  .drawer-right[open]  { animation: drawer-slide-right 0.3s ease; }
  .drawer-top[open]    { animation: drawer-slide-top 0.3s ease; }
  .drawer-bottom[open] { animation: drawer-slide-bottom 0.3s ease; }

  .drawer-has-overlay::backdrop { background: rgba(15, 23, 42, 0.55); }
  .drawer-no-overlay::backdrop { background: transparent; }

  @keyframes drawer-slide-left   { from { transform: translateX(-100%); } to { transform: translateX(0); } }
  @keyframes drawer-slide-right  { from { transform: translateX(100%); }  to { transform: translateX(0); } }
  @keyframes drawer-slide-top    { from { transform: translateY(-100%); } to { transform: translateY(0); } }
  @keyframes drawer-slide-bottom { from { transform: translateY(100%); }  to { transform: translateY(0); } }

  @media (prefers-reduced-motion: reduce) {
    .drawer-left[open], .drawer-right[open],
    .drawer-top[open], .drawer-bottom[open] { animation: none; }
  }
</style>

<script>
  function setupDrawers() {
    document
      .querySelectorAll<HTMLDialogElement>('dialog[data-drawer]')
      .forEach((dialog) => {
        if (dialog.dataset.initialized === 'true') return;
        dialog.dataset.initialized = 'true';

        const closeOnOverlay = dialog.dataset.closeOverlay === 'true';
        const closeOnEscape = dialog.dataset.closeEscape === 'true';
        const persistent = dialog.dataset.persistent === 'true';
        const triggerSel = dialog.dataset.trigger;

        const open = () => {
          if (!dialog.open) dialog.showModal();
        };
        const close = () => {
          if (dialog.open) dialog.close();
        };

        const selectors = [
          `[data-drawer-open="${dialog.id}"]`,
          `a[href="#${dialog.id}"]`,
          triggerSel || '',
        ]
          .filter(Boolean)
          .join(', ');

        document.querySelectorAll<HTMLElement>(selectors).forEach((trigger) => {
          if (trigger.dataset.drawerBound === 'true') return;
          trigger.dataset.drawerBound = 'true';
          trigger.addEventListener('click', (e) => {
            e.preventDefault();
            open();
          });
        });

        dialog
          .querySelectorAll<HTMLElement>('[data-drawer-close]')
          .forEach((btn) => btn.addEventListener('click', close));

        dialog.addEventListener('cancel', (e) => {
          if (!closeOnEscape || persistent) e.preventDefault();
        });

        if (closeOnOverlay && !persistent) {
          dialog.addEventListener('click', (e) => {
            if (e.target === dialog) close();
          });
        }

        if (dialog.dataset.openInitial === 'true') open();
      });
  }

  setupDrawers();
  document.addEventListener('astro:page-load', setupDrawers);
</script>
