---
/**
 * spotlight — Section image + texte côte à côte (mise en avant).
 *
 * Schema catalog : {
 *   image (REQUIS), imageAlt?, eyebrow?, eyebrowVariant?, title (REQUIS),
 *   text (REQUIS), cta?{label,href}, reverse?, background?
 * }
 *
 * Fonctionnement : rendu 100% serveur, aucun script. Image d'un côté, bloc
 * texte (eyebrow + titre + texte + CTA) de l'autre. `reverse` inverse l'ordre.
 *
 * Théming : consomme les variables `--bricks-color-*` (accent pour le CTA,
 * text/text-muted, surface) avec fallbacks. L'eyebrow utilise une palette de
 * teintes fixes selon `eyebrowVariant`. Marge racine `mb-12`.
 */
interface Cta {
  label: string;
  href: string;
}
interface Props {
  /** URL de l'image. REQUIS. */
  image: string;
  /** Texte alternatif de l'image. */
  imageAlt?: string;
  /** Petit texte au-dessus du titre. */
  eyebrow?: string;
  /** Teinte de l'eyebrow. Défaut : "teal". */
  eyebrowVariant?: 'teal' | 'amber' | 'rose' | 'slate' | 'chocolate';
  /** Titre. REQUIS. */
  title: string;
  /** Texte descriptif. REQUIS. */
  text: string;
  /** Bouton d'action optionnel. */
  cta?: Cta;
  /** Inverser image/texte. Défaut : false. */
  reverse?: boolean;
  /** Fond de la section. Défaut : "white". */
  background?: 'white' | 'alt' | 'rose';
  /** Override des classes du conteneur racine. */
  class?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  image,
  imageAlt = '',
  eyebrow,
  eyebrowVariant = 'teal',
  title,
  text,
  cta,
  reverse = false,
  background = 'white',
  class: customClass,
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const eyebrowClass: Record<string, string> = {
  teal: 'text-teal-600',
  amber: 'text-amber-600',
  rose: 'text-rose-600',
  slate: 'text-slate-600',
  chocolate: 'text-[#7b4b2a]',
};

const backgroundClass: Record<string, string> = {
  white: 'bg-[var(--bricks-color-surface,#ffffff)]',
  alt: 'bg-[var(--bricks-color-surface-alt,#f8fafc)]',
  rose: 'bg-rose-50',
};

const containerClass =
  customClass ??
  [
    'mb-12 overflow-hidden rounded-2xl',
    backgroundClass[background] ?? backgroundClass.white,
  ]
    .filter(Boolean)
    .join(' ');
---

<section id={`spotlight-${_brickId ?? ''}`} class:list={[containerClass]} {...rest}>
  <div class:list={['grid items-center gap-6 md:grid-cols-2 md:gap-10', reverse ? 'md:[direction:rtl]' : '']}>
    <div class:list={['md:[direction:ltr]', reverse ? 'md:order-2' : '']}>
      <img
        src={image}
        alt={imageAlt}
        loading="lazy"
        class="h-full max-h-[28rem] w-full object-cover"
      />
    </div>
    <div class:list={['p-6 md:p-10 md:[direction:ltr]', reverse ? 'md:order-1' : '']}>
      {eyebrow && (
        <p class:list={['mb-2 text-xs font-bold uppercase tracking-wider', eyebrowClass[eyebrowVariant] ?? eyebrowClass.teal]}>
          {eyebrow}
        </p>
      )}
      <h2 class="font-sans text-2xl font-extrabold tracking-tight text-[var(--bricks-color-text,#0f172a)] sm:text-3xl">
        {title}
      </h2>
      <p class="mt-4 text-[var(--bricks-color-text-muted,#475569)] leading-relaxed">
        {text}
      </p>
      {cta && (
        <a
          href={cta.href}
          class="mt-6 inline-block rounded-full bg-[var(--bricks-color-accent,#f97316)] px-6 py-3 text-sm font-semibold text-white transition hover:opacity-90"
        >
          {cta.label}
        </a>
      )}
    </div>
  </div>
</section>
