---
/**
 * date-picker — Sélecteur de date (input natif).
 *
 * Schema catalog : {
 *   name, label?, placeholder?, value?, min?, max?, format?, locale?, mode?,
 *   showTime?, showWeekNumbers?, disabledDates?, required?, disabled?, error?
 * }
 *
 * Utilise `<input type="date">` natif (ou `datetime-local` si showTime), ce qui
 * fournit le calendrier et la validation du navigateur sans dépendance. `mode`
 * range rend deux champs (début/fin). `min`/`max` bornent la plage. Les dates
 * désactivées sont exposées en data-* et bloquées par un petit script natif.
 *
 * Théming : consomme les variables `--bricks-color-*` (accent pour le focus-ring,
 * border/surface/text pour le champ, danger pour l'erreur) avec fallbacks.
 */
interface Props {
  /** Nom du champ. REQUIS. */
  name: string;
  /** Label du champ. */
  label?: string;
  /** Texte indicatif. Défaut : "Sélectionner une date". */
  placeholder?: string;
  /** Valeur initiale (ISO yyyy-mm-dd). */
  value?: string;
  /** Date min (ISO). */
  min?: string;
  /** Date max (ISO). */
  max?: string;
  /** Format d'affichage (indicatif). Défaut : "DD/MM/YYYY". */
  format?: string;
  /** Locale. Défaut : "fr". */
  locale?: string;
  /** Mode de sélection. Défaut : "single". */
  mode?: 'single' | 'range' | 'multiple';
  /** Inclure l'heure (datetime-local). Défaut : false. */
  showTime?: boolean;
  /** Afficher les numéros de semaine (indicatif). Défaut : false. */
  showWeekNumbers?: boolean;
  /** Dates désactivées (ISO). */
  disabledDates?: string[];
  /** Champ obligatoire. Défaut : false. */
  required?: boolean;
  /** Champ désactivé. Défaut : false. */
  disabled?: boolean;
  /** Message d'erreur. */
  error?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  name,
  label,
  placeholder = 'Sélectionner une date',
  value,
  min,
  max,
  format = 'DD/MM/YYYY',
  locale = 'fr',
  mode = 'single',
  showTime = false,
  showWeekNumbers = false,
  disabledDates = [],
  required = false,
  disabled = false,
  error,
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const uid = _brickId ?? Math.random().toString(36).slice(2, 8);
const inputId = `date-${name}-${uid}`;
const endId = `${inputId}-end`;
const errorId = `${inputId}-error`;
const inputType = showTime ? 'datetime-local' : 'date';

const labelClass =
  'mb-1.5 block font-sans text-sm font-semibold tracking-tight text-[var(--bricks-color-text,#0f172a)]';
const inputClass = [
  'block w-full rounded-lg border px-3.5 py-2.5 text-sm',
  'bg-[var(--bricks-color-surface,#ffffff)] text-[var(--bricks-color-text,#0f172a)]',
  'transition-colors duration-150',
  'focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-[var(--bricks-color-accent,#2563eb)]',
  'disabled:cursor-not-allowed disabled:opacity-60',
  error
    ? 'border-[var(--bricks-color-danger,#dc2626)]'
    : 'border-[var(--bricks-color-border,#e2e8f0)]',
].join(' ');

const disabledAttr = disabledDates.length ? disabledDates.join(',') : undefined;
const isRange = mode === 'range';
---

<div class="mb-6 w-full" data-datepicker data-disabled-dates={disabledAttr} {...rest}>
  {label && <label for={inputId} class={labelClass}>{label}{required && <span aria-hidden="true" class="text-[var(--bricks-color-danger,#dc2626)]"> *</span>}</label>}

  <div class:list={[isRange ? 'flex flex-col gap-2 sm:flex-row sm:items-center' : '']}>
    <input
      type={inputType}
      id={inputId}
      name={isRange ? `${name}_start` : name}
      value={value}
      min={min}
      max={max}
      title={placeholder}
      lang={locale}
      required={required || undefined}
      disabled={disabled || undefined}
      aria-label={label ?? placeholder}
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={error ? errorId : undefined}
      data-date-input
      class={inputClass}
    />
    {isRange && (
      <>
        <span aria-hidden="true" class="hidden text-[var(--bricks-color-text-muted,#475569)] sm:block">→</span>
        <input
          type={inputType}
          id={endId}
          name={`${name}_end`}
          min={min}
          max={max}
          lang={locale}
          required={required || undefined}
          disabled={disabled || undefined}
          aria-label="Date de fin"
          data-date-input
          class={inputClass}
        />
      </>
    )}
  </div>

  {error && <p id={errorId} class="mt-1.5 text-xs font-medium text-[var(--bricks-color-danger,#dc2626)]">{error}</p>}
</div>

<script>
  function setupDatePicker(root: HTMLElement) {
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const disabledDates = (root.dataset.disabledDates ?? '')
      .split(',')
      .map((d) => d.trim())
      .filter(Boolean);

    const inputs = root.querySelectorAll<HTMLInputElement>('[data-date-input]');
    inputs.forEach((input) => {
      if (disabledDates.length) {
        input.addEventListener('change', () => {
          const day = input.value.slice(0, 10);
          if (day && disabledDates.includes(day)) {
            input.setCustomValidity('Cette date n’est pas disponible.');
            input.reportValidity();
          } else {
            input.setCustomValidity('');
          }
        });
      }
    });

    // Mode range : bornes croisées entre début et fin.
    if (inputs.length === 2) {
      const [start, end] = Array.from(inputs);
      start.addEventListener('change', () => {
        if (start.value) end.min = start.value;
      });
      end.addEventListener('change', () => {
        if (end.value) start.max = end.value;
      });
    }
  }

  function initAllDatePicker() {
    document.querySelectorAll<HTMLElement>('[data-datepicker]').forEach((el) => setupDatePicker(el));
  }

  initAllDatePicker();
  document.addEventListener('astro:page-load', initAllDatePicker);
</script>
