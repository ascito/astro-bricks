---
/**
 * stepper — Étapes de progression (liste d'étapes avec état).
 *
 * Schema catalog : {
 *   steps (REQUIS) [{label, description?, icon?, href?}],
 *   currentStep?, variant?, orientation?, size?, clickable?,
 *   showNumbers?, color?, className?
 * }
 *
 * Rendu : liste ordonnée (<ol>) statique côté serveur. Chaque étape porte un état
 * dérivé de `currentStep` : completed / current / upcoming. Si `clickable` et `href`,
 * les étapes sont des liens. Pas de script (état figé au rendu).
 *
 * Théming : consomme les variables `--bricks-color-*` (accent pour completed/current,
 * muted/border pour upcoming) avec fallbacks.
 */
interface Step {
  label: string;
  description?: string;
  /** Emoji/glyphe optionnel (remplace le numéro). */
  icon?: string;
  /** Lien (si clickable). */
  href?: string;
}

interface Props {
  /** Liste des étapes. */
  steps: Step[];
  /** Étape actuelle (0-indexed). Défaut : 0. */
  currentStep?: number;
  /** Style. Défaut : 'default'. */
  variant?: 'default' | 'simple' | 'dots' | 'arrows';
  /** Orientation. Défaut : 'horizontal'. */
  orientation?: 'horizontal' | 'vertical';
  /** Taille. Défaut : 'md'. */
  size?: 'sm' | 'md' | 'lg';
  /** Étapes cliquables. Défaut : false. */
  clickable?: boolean;
  /** Afficher les numéros d'étapes. Défaut : true. */
  showNumbers?: boolean;
  /** Couleur. Défaut : 'primary'. */
  color?: 'primary' | 'success' | 'secondary';
  /** Classes additionnelles. */
  className?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  steps = [],
  currentStep = 0,
  variant = 'default',
  orientation = 'horizontal',
  size = 'md',
  clickable = false,
  showNumbers = true,
  color = 'primary',
  className = '',
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const vertical = orientation === 'vertical';
const dots = variant === 'dots';

const SIZE_MARKER: Record<string, string> = {
  sm: dots ? 'h-3 w-3' : 'h-7 w-7 text-xs',
  md: dots ? 'h-4 w-4' : 'h-9 w-9 text-sm',
  lg: dots ? 'h-5 w-5' : 'h-11 w-11 text-base',
};

const accent = 'var(--bricks-color-accent,#2563eb)';
const muted = 'var(--bricks-color-border,#cbd5e1)';

function stepState(index: number): 'completed' | 'current' | 'upcoming' {
  if (index < currentStep) return 'completed';
  if (index === currentStep) return 'current';
  return 'upcoming';
}
---
<ol
  data-brick="stepper"
  aria-label="Progression par étapes"
  class:list={[
    'mb-12 flex',
    vertical ? 'flex-col gap-0' : 'items-start',
    className,
  ]}
  {...rest}
>
  {steps.map((step, index) => {
    const state = stepState(index);
    const isLast = index === steps.length - 1;
    const Tag = clickable && step.href ? 'a' : 'div';
    const markerBg =
      state === 'upcoming'
        ? `border-2 bg-[var(--bricks-color-surface,#ffffff)]`
        : 'text-white';
    return (
      <li
        class:list={[
          'relative flex',
          vertical ? 'gap-4 pb-8 last:pb-0' : 'flex-1 flex-col items-center text-center',
        ]}
        aria-current={state === 'current' ? 'step' : undefined}
      >
        {/* Trait de liaison */}
        {!isLast && (
          <span
            aria-hidden="true"
            class:list={[
              vertical
                ? 'absolute left-0 top-0 -z-0 w-0.5 -translate-x-1/2'
                : 'absolute top-0 left-1/2 -z-0 h-0.5 w-full',
            ]}
            style={
              vertical
                ? `left:${size === 'lg' ? '1.375rem' : size === 'sm' ? '0.875rem' : '1.125rem'}; top:1.5rem; bottom:0; height:auto; background:${index < currentStep ? accent : muted}`
                : `top:${size === 'lg' ? '1.375rem' : size === 'sm' ? '0.875rem' : '1.125rem'}; left:50%; background:${index < currentStep ? accent : muted}`
            }
          ></span>
        )}

        <Tag
          href={clickable && step.href ? step.href : undefined}
          class:list={[
            'relative z-10 flex',
            vertical ? 'flex-shrink-0' : 'flex-col items-center',
            clickable && step.href ? 'cursor-pointer' : '',
          ]}
        >
          {!dots && (
            <span
              class:list={[
                'flex items-center justify-center rounded-full font-sans font-extrabold',
                SIZE_MARKER[size],
                markerBg,
              ]}
              style={
                state === 'upcoming'
                  ? `border-color:${muted}; color:var(--bricks-color-text-muted,#475569)`
                  : `background:${accent}`
              }
            >
              {step.icon
                ? <span aria-hidden="true">{step.icon}</span>
                : state === 'completed'
                  ? <span aria-hidden="true">✓</span>
                  : showNumbers
                    ? index + 1
                    : ''}
            </span>
          )}
          {dots && (
            <span
              class:list={['flex rounded-full', SIZE_MARKER[size]]}
              style={state === 'upcoming' ? `background:${muted}` : `background:${accent}`}
              aria-hidden="true"
            ></span>
          )}
        </Tag>

        <div class:list={[vertical ? 'pt-1' : 'mt-2 px-1']}>
          <p
            class:list={['font-semibold tracking-tight', size === 'lg' ? 'text-base' : 'text-sm']}
            style={
              state === 'upcoming'
                ? 'color:var(--bricks-color-text-muted,#94a3b8)'
                : 'color:var(--bricks-color-text,#0f172a)'
            }
          >{step.label}</p>
          {step.description && variant !== 'simple' && (
            <p class="mt-0.5 text-xs leading-relaxed text-[var(--bricks-color-text-muted,#475569)]">
              {step.description}
            </p>
          )}
        </div>
      </li>
    );
  })}
</ol>
