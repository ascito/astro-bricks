---
/**
 * stats — Bandeau de chiffres clés (catalog composite)
 * Schema : items[] {value, label, prefix, suffix, icon, description}, columns 2-5, variant, size, align, animated, color
 */
interface StatItem {
  value: string;
  label: string;
  prefix?: string;
  suffix?: string;
  icon?: string;
  description?: string;
}
interface Props {
  items: StatItem[];
  columns?: 2 | 3 | 4 | 5;
  variant?: 'default' | 'card' | 'minimal' | 'bordered';
  size?: 'sm' | 'md' | 'lg' | 'xl';
  align?: 'left' | 'center' | 'right';
  animated?: boolean;
  duration?: number;
  color?: 'default' | 'primary' | 'gradient';
  _brickId?: string;
  _brickType?: string;
}

const {
  items,
  columns = 4,
  variant = 'default',
  size = 'lg',
  align = 'center',
  color = 'default',
} = Astro.props;

const gridCols = { 2: 'grid-cols-2', 3: 'grid-cols-2 md:grid-cols-3', 4: 'grid-cols-2 md:grid-cols-4', 5: 'grid-cols-2 md:grid-cols-5' }[columns];

const itemWrapperClass = {
  default: '',
  card: 'p-5 bg-white border border-slate-200 rounded-2xl',
  minimal: 'py-2',
  bordered: 'p-5 border border-slate-200 rounded-lg',
}[variant];

const valueSizeClass = {
  sm: 'text-2xl',
  md: 'text-3xl',
  lg: 'text-4xl md:text-5xl',
  xl: 'text-5xl md:text-6xl',
}[size];

const valueColorClass = {
  default: 'text-slate-900',
  primary: 'text-indigo-700',
  gradient: 'bg-gradient-to-br from-indigo-600 to-rose-500 bg-clip-text text-transparent',
}[color];

const alignClass = { left: 'text-left', center: 'text-center', right: 'text-right' }[align];
---
<div class={`grid gap-6 ${gridCols} ${alignClass}`}>
  {items.map((item) => (
    <div class={itemWrapperClass}>
      {item.icon && <div class="text-2xl mb-2">{item.icon}</div>}
      <p class={`font-sans font-extrabold tracking-tight leading-tight ${valueSizeClass} ${valueColorClass}`}>
        {item.prefix && <span class="text-2xl align-top mr-0.5">{item.prefix}</span>}
        {item.value}
        {item.suffix && <span class="text-2xl align-top ml-0.5">{item.suffix}</span>}
      </p>
      <p class="mt-1 text-sm font-semibold uppercase tracking-wider text-slate-500">{item.label}</p>
      {item.description && <p class="mt-2 text-sm text-slate-600">{item.description}</p>}
    </div>
  ))}
</div>
