---
/**
 * list — Liste avec icônes, checks ou numéros.
 * Schema catalog : {
 *   items (REQUIS), variant?, size?, gap?, divided?,
 *   columns?, icon?, iconColor?, showValue?
 * }
 *
 * items : string | { label/text, value?, icon?, href? }
 * Marge basse mb-6 (élément inline). Théming var(--bricks-color-*).
 */
interface ListItem {
  label?: string;
  text?: string;
  value?: string;
  icon?: string;
  href?: string;
}

interface Props {
  /** Éléments de la liste. REQUIS. */
  items: (string | ListItem)[];
  /** Style de puce. Défaut : "bullet". */
  variant?: 'bullet' | 'check' | 'number' | 'icon' | 'none';
  /** Taille. Défaut : "md". */
  size?: 'sm' | 'md' | 'lg';
  /** Espacement vertical. Défaut : "md". */
  gap?: 'none' | 'sm' | 'md' | 'lg';
  /** Séparateurs entre items. Défaut : false. */
  divided?: boolean;
  /** Nombre de colonnes. Défaut : 1. */
  columns?: number;
  /** Icône par défaut pour variant="icon". */
  icon?: string;
  /** Couleur de la puce/icône. Défaut : "primary". */
  iconColor?: 'primary' | 'secondary' | 'success' | 'muted' | 'current';
  /** Afficher une colonne valeur à droite. Défaut : false. */
  showValue?: boolean;
  class?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  items,
  variant = 'bullet',
  size = 'md',
  gap = 'md',
  divided = false,
  columns = 1,
  icon,
  iconColor = 'primary',
  showValue = false,
  class: customClass,
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const sizeClass = { sm: 'text-sm', md: 'text-base', lg: 'text-lg' }[size];
const gapClass = { none: 'gap-0', sm: 'gap-1.5', md: 'gap-2.5', lg: 'gap-4' }[gap];

const markerColor = {
  primary: 'var(--bricks-color-accent,#2563eb)',
  secondary: 'var(--bricks-color-secondary,#64748b)',
  success: 'var(--bricks-color-success,#16a34a)',
  muted: 'var(--bricks-color-text-muted,#475569)',
  current: 'currentColor',
}[iconColor];

const normalized = items.map((it) =>
  typeof it === 'string' ? { label: it } : { ...it, label: it.label ?? it.text }
);

const listTag = variant === 'number' ? 'ol' : 'ul';
const Tag = listTag;

const gridStyle =
  columns > 1
    ? `display:grid;grid-template-columns:repeat(${columns},minmax(0,1fr));`
    : '';
---

<Tag
  class:list={['mb-6 list-none m-0 p-0', sizeClass, columns > 1 ? '' : `flex flex-col ${gapClass}`, customClass]}
  style={gridStyle ? `${gridStyle}gap:${{ none: '0', sm: '0.375rem', md: '0.625rem', lg: '1rem' }[gap]}` : undefined}
  {...rest}
>
  {normalized.map((item, i) => (
    <li
      class:list={[
        'flex items-start gap-2.5',
        divided ? 'border-b border-[var(--bricks-color-border,#e2e8f0)] pb-2' : '',
        showValue ? 'justify-between' : '',
      ]}
    >
      <span class="flex items-start gap-2.5 min-w-0">
        {variant === 'check' && (
          <svg aria-hidden="true" class="mt-0.5 shrink-0" width="18" height="18" viewBox="0 0 20 20" fill="none" style={`color:${markerColor}`}>
            <path d="M16.7 5.3 8 14l-4.7-4.7" stroke="currentColor" stroke-width="2.2" stroke-linecap="round" stroke-linejoin="round" />
          </svg>
        )}
        {variant === 'number' && (
          <span class="mt-0.5 shrink-0 font-semibold tabular-nums" style={`color:${markerColor}`}>
            {i + 1}.
          </span>
        )}
        {variant === 'bullet' && (
          <span class="mt-2 shrink-0 rounded-full" style={`width:0.4rem;height:0.4rem;background:${markerColor}`} aria-hidden="true"></span>
        )}
        {variant === 'icon' && (item.icon || icon) && (
          <span class="mt-0.5 shrink-0" style={`color:${markerColor}`} data-icon={item.icon ?? icon} aria-hidden="true">•</span>
        )}
        <span class="text-[var(--bricks-color-text,#0f172a)] min-w-0">
          {item.href ? (
            <a href={item.href} class="hover:underline text-[var(--bricks-color-accent,#2563eb)]">{item.label}</a>
          ) : (
            item.label
          )}
        </span>
      </span>
      {showValue && item.value && (
        <span class="shrink-0 font-semibold text-[var(--bricks-color-text-muted,#475569)] tabular-nums">{item.value}</span>
      )}
    </li>
  ))}
</Tag>
