---
/**
 * password-confirm — Double champ mot de passe avec validation de correspondance.
 *
 * Schema catalog : {
 *   passwordName?, confirmName?, passwordLabel?, confirmLabel?,
 *   passwordPlaceholder?, confirmPlaceholder?, showStrength?, showToggle?,
 *   minLength?, requireUppercase?, requireLowercase?, requireNumber?,
 *   requireSpecial?, required?, error?
 * }
 *
 * Deux <input type="password"> natifs. Le serveur rend la coquille (champs +
 * indicateur de force + zone de feedback). Un script client compare les deux
 * champs, calcule la force selon les règles `require*`/`minLength`, gère le
 * bouton afficher/masquer, et pose la validité native via setCustomValidity.
 * Zéro dépendance externe, compatible Astro View Transitions.
 *
 * Théming : consomme les variables `--bricks-color-*` (accent pour le focus-ring,
 * border/surface/text pour les champs, danger/warning/success pour la force).
 */
interface Props {
  /** Nom du champ mot de passe. Défaut : "password". */
  passwordName?: string;
  /** Nom du champ confirmation. Défaut : "password_confirmation". */
  confirmName?: string;
  /** Label du mot de passe. Défaut : "Mot de passe". */
  passwordLabel?: string;
  /** Label de la confirmation. Défaut : "Confirmer le mot de passe". */
  confirmLabel?: string;
  /** Placeholder du mot de passe. */
  passwordPlaceholder?: string;
  /** Placeholder de la confirmation. */
  confirmPlaceholder?: string;
  /** Afficher l'indicateur de force. Défaut : true. */
  showStrength?: boolean;
  /** Afficher le bouton afficher/masquer. Défaut : true. */
  showToggle?: boolean;
  /** Longueur minimale. Défaut : 8. */
  minLength?: number;
  /** Exiger une majuscule. Défaut : true. */
  requireUppercase?: boolean;
  /** Exiger une minuscule. Défaut : true. */
  requireLowercase?: boolean;
  /** Exiger un chiffre. Défaut : true. */
  requireNumber?: boolean;
  /** Exiger un caractère spécial. Défaut : false. */
  requireSpecial?: boolean;
  /** Champs obligatoires. Défaut : true. */
  required?: boolean;
  /** Message d'erreur global. */
  error?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  passwordName = 'password',
  confirmName = 'password_confirmation',
  passwordLabel = 'Mot de passe',
  confirmLabel = 'Confirmer le mot de passe',
  passwordPlaceholder,
  confirmPlaceholder,
  showStrength = true,
  showToggle = true,
  minLength = 8,
  requireUppercase = true,
  requireLowercase = true,
  requireNumber = true,
  requireSpecial = false,
  required = true,
  error,
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const uid = _brickId ?? Math.random().toString(36).slice(2, 8);
const rootId = `pwd-confirm-${uid}`;
const passwordId = `${rootId}-pwd`;
const confirmId = `${rootId}-confirm`;
const feedbackId = `${rootId}-feedback`;

const labelClass =
  'mb-1.5 block font-sans text-sm font-semibold tracking-tight text-[var(--bricks-color-text,#0f172a)]';
const inputClass = [
  'block w-full rounded-lg border border-[var(--bricks-color-border,#e2e8f0)] px-3.5 py-2.5 pr-11 text-sm',
  'bg-[var(--bricks-color-surface,#ffffff)] text-[var(--bricks-color-text,#0f172a)]',
  'placeholder:text-[var(--bricks-color-text-faint,#94a3b8)] transition-colors duration-150',
  'focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-[var(--bricks-color-accent,#2563eb)]',
].join(' ');
const toggleClass =
  'absolute inset-y-0 right-0 flex items-center px-3 text-[var(--bricks-color-text-muted,#475569)] hover:text-[var(--bricks-color-text,#0f172a)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--bricks-color-accent,#2563eb)] rounded-r-lg';
---

<div
  id={rootId}
  data-pwd-confirm
  data-min-length={minLength}
  data-require-uppercase={requireUppercase ? 'true' : 'false'}
  data-require-lowercase={requireLowercase ? 'true' : 'false'}
  data-require-number={requireNumber ? 'true' : 'false'}
  data-require-special={requireSpecial ? 'true' : 'false'}
  data-show-strength={showStrength ? 'true' : 'false'}
  class="mb-6 w-full max-w-md space-y-4"
  {...rest}
>
  {error && (
    <p role="alert" class="rounded-lg border border-[var(--bricks-color-danger,#dc2626)] bg-[var(--bricks-color-danger,#dc2626)]/10 px-3.5 py-2.5 text-sm text-[var(--bricks-color-danger,#dc2626)]">{error}</p>
  )}

  <div>
    <label for={passwordId} class={labelClass}>{passwordLabel}</label>
    <div class="relative">
      <input
        type="password"
        id={passwordId}
        name={passwordName}
        placeholder={passwordPlaceholder}
        required={required || undefined}
        minlength={minLength}
        autocomplete="new-password"
        aria-describedby={showStrength ? `${rootId}-strength` : undefined}
        data-pwd-input
        class={inputClass}
      />
      {showToggle && (
        <button type="button" data-pwd-toggle={passwordId} aria-label="Afficher le mot de passe" aria-pressed="false" class={toggleClass}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" />
          </svg>
        </button>
      )}
    </div>

    {showStrength && (
      <div id={`${rootId}-strength`} class="mt-2" aria-hidden="true">
        <div class="h-1.5 w-full overflow-hidden rounded-full bg-[var(--bricks-color-muted,#f1f5f9)]">
          <div data-pwd-strength-bar class="h-full w-0 rounded-full bg-[var(--bricks-color-danger,#dc2626)] transition-all duration-200"></div>
        </div>
        <p data-pwd-strength-label class="mt-1 text-xs text-[var(--bricks-color-text-muted,#475569)]"></p>
      </div>
    )}
  </div>

  <div>
    <label for={confirmId} class={labelClass}>{confirmLabel}</label>
    <div class="relative">
      <input
        type="password"
        id={confirmId}
        name={confirmName}
        placeholder={confirmPlaceholder}
        required={required || undefined}
        minlength={minLength}
        autocomplete="new-password"
        aria-describedby={feedbackId}
        data-pwd-confirm-input
        class={inputClass}
      />
      {showToggle && (
        <button type="button" data-pwd-toggle={confirmId} aria-label="Afficher le mot de passe" aria-pressed="false" class={toggleClass}>
          <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7Z" /><circle cx="12" cy="12" r="3" />
          </svg>
        </button>
      )}
    </div>
    <p id={feedbackId} data-pwd-feedback role="status" aria-live="polite" class="mt-1.5 text-xs"></p>
  </div>
</div>

<script>
  type Rules = {
    minLength: number;
    requireUppercase: boolean;
    requireLowercase: boolean;
    requireNumber: boolean;
    requireSpecial: boolean;
  };

  function scorePassword(value: string, rules: Rules): number {
    if (!value) return 0;
    let score = 0;
    if (value.length >= rules.minLength) score++;
    if (/[A-Z]/.test(value)) score++;
    if (/[a-z]/.test(value)) score++;
    if (/[0-9]/.test(value)) score++;
    if (/[^A-Za-z0-9]/.test(value)) score++;
    return score;
  }

  function meetsRules(value: string, rules: Rules): boolean {
    if (value.length < rules.minLength) return false;
    if (rules.requireUppercase && !/[A-Z]/.test(value)) return false;
    if (rules.requireLowercase && !/[a-z]/.test(value)) return false;
    if (rules.requireNumber && !/[0-9]/.test(value)) return false;
    if (rules.requireSpecial && !/[^A-Za-z0-9]/.test(value)) return false;
    return true;
  }

  function setupPwdConfirm(root: HTMLElement) {
    if (root.dataset.initialized === 'true') return;
    root.dataset.initialized = 'true';

    const rules: Rules = {
      minLength: Number(root.dataset.minLength ?? 8),
      requireUppercase: root.dataset.requireUppercase === 'true',
      requireLowercase: root.dataset.requireLowercase === 'true',
      requireNumber: root.dataset.requireNumber === 'true',
      requireSpecial: root.dataset.requireSpecial === 'true',
    };
    const showStrength = root.dataset.showStrength === 'true';

    const pwd = root.querySelector<HTMLInputElement>('[data-pwd-input]');
    const confirm = root.querySelector<HTMLInputElement>('[data-pwd-confirm-input]');
    const feedback = root.querySelector<HTMLElement>('[data-pwd-feedback]');
    const bar = root.querySelector<HTMLElement>('[data-pwd-strength-bar]');
    const strengthLabel = root.querySelector<HTMLElement>('[data-pwd-strength-label]');
    if (!pwd || !confirm) return;

    const labels = ['Très faible', 'Faible', 'Moyen', 'Bon', 'Fort', 'Excellent'];
    const colors = [
      'var(--bricks-color-danger,#dc2626)',
      'var(--bricks-color-danger,#dc2626)',
      'var(--bricks-color-warning,#d97706)',
      'var(--bricks-color-warning,#d97706)',
      'var(--bricks-color-success,#16a34a)',
      'var(--bricks-color-success,#16a34a)',
    ];

    const updateStrength = () => {
      if (!showStrength || !bar) return;
      const score = scorePassword(pwd.value, rules);
      bar.style.width = `${(score / 5) * 100}%`;
      bar.style.backgroundColor = colors[score];
      if (strengthLabel) strengthLabel.textContent = pwd.value ? labels[score] : '';

      if (pwd.value && !meetsRules(pwd.value, rules)) {
        pwd.setCustomValidity('Le mot de passe ne respecte pas les critères requis.');
      } else {
        pwd.setCustomValidity('');
      }
    };

    const updateMatch = () => {
      if (!feedback) return;
      if (!confirm.value) {
        feedback.textContent = '';
        confirm.setCustomValidity('');
        return;
      }
      if (pwd.value === confirm.value) {
        feedback.textContent = 'Les mots de passe correspondent.';
        feedback.style.color = 'var(--bricks-color-success,#16a34a)';
        confirm.setCustomValidity('');
      } else {
        feedback.textContent = 'Les mots de passe ne correspondent pas.';
        feedback.style.color = 'var(--bricks-color-danger,#dc2626)';
        confirm.setCustomValidity('Les mots de passe ne correspondent pas.');
      }
    };

    pwd.addEventListener('input', () => {
      updateStrength();
      updateMatch();
    });
    confirm.addEventListener('input', updateMatch);

    updateStrength();
    updateMatch();
  }

  function initAllPwdConfirm() {
    document
      .querySelectorAll<HTMLElement>('[data-pwd-confirm]')
      .forEach((el) => setupPwdConfirm(el));

    document.querySelectorAll<HTMLButtonElement>('[data-pwd-toggle]').forEach((btn) => {
      if (btn.dataset.initialized === 'true') return;
      btn.dataset.initialized = 'true';
      btn.addEventListener('click', () => {
        const targetId = btn.getAttribute('data-pwd-toggle');
        const input = targetId && document.getElementById(targetId);
        if (!input || !(input instanceof HTMLInputElement)) return;
        const reveal = input.type === 'password';
        input.type = reveal ? 'text' : 'password';
        btn.setAttribute('aria-pressed', reveal ? 'true' : 'false');
        btn.setAttribute('aria-label', reveal ? 'Masquer le mot de passe' : 'Afficher le mot de passe');
      });
    });
  }

  initAllPwdConfirm();
  document.addEventListener('astro:page-load', initAllPwdConfirm);
</script>
