---
/**
 * search-input — Champ de recherche.
 *
 * Schema catalog : {
 *   name?, placeholder?, value?, action?, method?, instant?, debounce?,
 *   minLength?, showClear?, showSubmit?, size?, variant?, suggestions?,
 *   autocomplete?
 * }
 *
 * <form> + `<input type="search">` natifs. Le serveur rend la coquille (champ,
 * bouton effacer, bouton soumettre, datalist de suggestions). Un script client
 * gère l'effacement, et — si `instant` — émet un évènement `search:input` après
 * `debounce` ms au-delà de `minLength` (pour brancher un filtrage côté app).
 *
 * Théming : consomme les variables `--bricks-color-*` (accent pour le bouton/
 * focus-ring, border/surface/text, text-muted pour l'icône) avec fallbacks.
 */
interface Props {
  /** Nom du champ. Défaut : "search". */
  name?: string;
  /** Texte indicatif. Défaut : "Rechercher...". */
  placeholder?: string;
  /** Valeur initiale. */
  value?: string;
  /** URL d'action du formulaire. */
  action?: string;
  /** Méthode HTTP. Défaut : "get". */
  method?: 'get' | 'post';
  /** Recherche instantanée à la frappe. Défaut : false. */
  instant?: boolean;
  /** Délai d'anti-rebond (ms). Défaut : 300. */
  debounce?: number;
  /** Longueur min avant déclenchement. Défaut : 2. */
  minLength?: number;
  /** Afficher le bouton effacer. Défaut : true. */
  showClear?: boolean;
  /** Afficher le bouton soumettre. Défaut : true. */
  showSubmit?: boolean;
  /** Taille du champ. Défaut : "md". */
  size?: 'sm' | 'md' | 'lg';
  /** Variante visuelle. Défaut : "default". */
  variant?: 'default' | 'outlined' | 'filled';
  /** Suggestions (datalist). */
  suggestions?: string[];
  /** Autocomplétion. Défaut : "off". */
  autocomplete?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  name = 'search',
  placeholder = 'Rechercher...',
  value,
  action,
  method = 'get',
  instant = false,
  debounce = 300,
  minLength = 2,
  showClear = true,
  showSubmit = true,
  size = 'md',
  variant = 'default',
  suggestions = [],
  autocomplete = 'off',
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const uid = _brickId ?? Math.random().toString(36).slice(2, 8);
const inputId = `search-${name}-${uid}`;
const listId = suggestions.length ? `${inputId}-list` : undefined;

const sizeClass = { sm: 'py-2 text-sm', md: 'py-2.5 text-sm', lg: 'py-3 text-base' }[size];
const variantClass = {
  default: 'border border-[var(--bricks-color-border,#e2e8f0)] bg-[var(--bricks-color-surface,#ffffff)]',
  outlined: 'border-2 border-[var(--bricks-color-border,#e2e8f0)] bg-transparent',
  filled: 'border border-transparent bg-[var(--bricks-color-muted,#f1f5f9)]',
}[variant];
---

<form
  action={action}
  method={method}
  role="search"
  data-search
  data-instant={instant ? 'true' : 'false'}
  data-debounce={debounce}
  data-min-length={minLength}
  class="mb-6 w-full"
  {...rest}
>
  <div
    class:list={[
      'flex items-center gap-1.5 rounded-lg pl-3 pr-1.5 transition-colors duration-150',
      'focus-within:ring-2 focus-within:ring-offset-1 focus-within:ring-[var(--bricks-color-accent,#2563eb)]',
      variantClass,
    ]}
  >
    <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true" class="flex-shrink-0 text-[var(--bricks-color-text-muted,#475569)]">
      <circle cx="11" cy="11" r="8" /><path d="m21 21-4.3-4.3" />
    </svg>

    <label for={inputId} class="sr-only">{placeholder}</label>
    <input
      type="search"
      id={inputId}
      name={name}
      value={value}
      placeholder={placeholder}
      minlength={minLength}
      autocomplete={autocomplete}
      list={listId}
      data-search-input
      class:list={[
        'min-w-0 flex-1 bg-transparent text-[var(--bricks-color-text,#0f172a)] outline-none',
        'placeholder:text-[var(--bricks-color-text-faint,#94a3b8)]',
        sizeClass,
      ]}
    />

    {showClear && (
      <button
        type="button"
        data-search-clear
        aria-label="Effacer la recherche"
        hidden
        class="flex-shrink-0 rounded p-1.5 text-[var(--bricks-color-text-muted,#475569)] hover:text-[var(--bricks-color-text,#0f172a)] focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--bricks-color-accent,#2563eb)]"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M18 6 6 18" /><path d="m6 6 12 12" />
        </svg>
      </button>
    )}

    {showSubmit && (
      <button
        type="submit"
        aria-label="Lancer la recherche"
        class="flex-shrink-0 rounded-md bg-[var(--bricks-color-accent,#2563eb)] px-3 py-2 text-sm font-semibold text-white transition-opacity hover:opacity-90 focus:outline-none focus-visible:ring-2 focus-visible:ring-offset-1 focus-visible:ring-[var(--bricks-color-accent,#2563eb)]"
      >
        OK
      </button>
    )}
  </div>

  {suggestions.length > 0 && (
    <datalist id={listId}>
      {suggestions.map((s) => <option value={s} />)}
    </datalist>
  )}
</form>

<script>
  function setupSearch(form: HTMLElement) {
    if (form.dataset.initialized === 'true') return;
    form.dataset.initialized = 'true';

    const input = form.querySelector<HTMLInputElement>('[data-search-input]');
    const clear = form.querySelector<HTMLButtonElement>('[data-search-clear]');
    if (!input) return;

    const instant = form.dataset.instant === 'true';
    const debounce = Number(form.dataset.debounce ?? 300);
    const minLength = Number(form.dataset.minLength ?? 2);

    const syncClear = () => {
      if (clear) clear.hidden = input.value.length === 0;
    };
    syncClear();

    if (clear) {
      clear.addEventListener('click', () => {
        input.value = '';
        syncClear();
        input.focus();
        if (instant) {
          form.dispatchEvent(
            new CustomEvent('search:input', { bubbles: true, detail: { value: '' } })
          );
        }
      });
    }

    let timer: ReturnType<typeof setTimeout> | undefined;
    input.addEventListener('input', () => {
      syncClear();
      if (!instant) return;
      clearTimeout(timer);
      const value = input.value;
      if (value.length && value.length < minLength) return;
      timer = setTimeout(() => {
        form.dispatchEvent(
          new CustomEvent('search:input', { bubbles: true, detail: { value } })
        );
      }, debounce);
    });
  }

  function initAllSearch() {
    document.querySelectorAll<HTMLElement>('[data-search]').forEach((el) => setupSearch(el));
  }

  initAllSearch();
  document.addEventListener('astro:page-load', initAllSearch);
</script>
