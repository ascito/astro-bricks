---
/**
 * Header — En-tête du site avec logo + nav desktop + burger mobile.
 *
 * Paramétrable via props :
 *  - `brand` : logo + alt + lien
 *  - `items` : liste des entrées de navigation
 *  - `cta` : entrée mise en avant (optionnelle, style bouton)
 *  - `palette` : classes Tailwind pour les couleurs actives/hover
 *
 * Pattern responsive : `<details>` natif pour le menu mobile (zéro JS).
 *
 * Usage :
 * ```astro
 * <Header
 *   brand={{ logoSrc: '/images/logo.svg', label: 'Saunaguide' }}
 *   items={siteConfig.nav.items}
 *   cta={{ href: '/comparatif-2026', label: 'Comparatif 2026' }}
 *   palette={{
 *     activeText: 'text-amber-800',
 *     hoverText: 'hover:text-amber-800',
 *     hoverBg: 'hover:bg-stone-50',
 *     ctaBg: 'bg-amber-800',
 *     ctaHoverBg: 'hover:bg-amber-900',
 *   }}
 * />
 * ```
 */

interface NavItem {
  href: string;
  label: string;
}

interface BrandConfig {
  /** Path vers le logo SVG ou PNG. */
  logoSrc: string;
  /** Texte alternatif. */
  label: string;
  /** Lien du logo. Défaut: `/`. */
  href?: string;
  /** Hauteur du logo en px. Défaut: 40. */
  logoHeight?: number;
}

interface Cta extends NavItem {
  /** Si fourni, override le style par défaut. */
  className?: string;
}

interface HeaderPalette {
  /** Classe pour le texte de l'item actif. Défaut: `text-slate-900`. */
  activeText?: string;
  /** Classe pour le hover des items. Défaut: `hover:text-slate-900`. */
  hoverText?: string;
  /** Classe pour le hover background des items. Défaut: `hover:bg-slate-50`. */
  hoverBg?: string;
  /** Classe pour le background du CTA. Défaut: `bg-slate-800`. */
  ctaBg?: string;
  /** Classe pour le hover background du CTA. Défaut: `hover:bg-slate-900`. */
  ctaHoverBg?: string;
}

interface Props {
  brand: BrandConfig;
  items: NavItem[];
  cta?: Cta;
  palette?: HeaderPalette;
  /** Classes additionnelles sur le `<header>`. */
  class?: string;
}

const {
  brand,
  items,
  cta,
  palette = {},
  class: customClass = '',
} = Astro.props;

const {
  activeText = 'text-slate-900',
  hoverText = 'hover:text-slate-900',
  hoverBg = 'hover:bg-slate-50',
  ctaBg = 'bg-slate-800',
  ctaHoverBg = 'hover:bg-slate-900',
} = palette;

const {
  href: brandHref = '/',
  logoHeight = 40,
} = brand;

const currentPath = Astro.url.pathname;
const isActive = (href: string) =>
  currentPath === href || currentPath.startsWith(href + '/');
---

<header
  data-brick="header"
  class:list={[
    'bg-white/95 backdrop-blur-sm border-b border-slate-100 sticky top-0 z-40',
    customClass,
  ]}
>
  <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
    <div class="flex justify-between items-center h-16">
      {/* Logo */}
      <a href={brandHref} class="flex items-center group" aria-label={`${brand.label} — Accueil`}>
        <img
          src={brand.logoSrc}
          alt={brand.label}
          class="w-auto group-hover:opacity-90 transition-opacity"
          height={logoHeight}
          style={`height: ${logoHeight}px`}
        />
      </a>

      {/* Nav desktop */}
      <nav class="hidden md:flex items-center gap-1" aria-label="Navigation principale">
        {items.map((item) => (
          <a
            href={item.href}
            class:list={[
              'text-sm font-medium px-4 py-2 rounded-md transition-colors',
              isActive(item.href)
                ? activeText
                : `text-slate-700 ${hoverText} ${hoverBg}`,
            ]}
          >
            {item.label}
          </a>
        ))}

        {cta && (
          <a
            href={cta.href}
            class:list={cta.className ?? [
              'text-sm font-semibold ml-2 px-4 py-2 rounded-full transition-colors text-white shadow-md',
              ctaBg,
              ctaHoverBg,
            ]}
          >
            {cta.label}
          </a>
        )}
      </nav>

      {/* Burger mobile */}
      <details class="md:hidden relative">
        <summary class="list-none cursor-pointer p-2 rounded-lg hover:bg-slate-100" aria-label="Ouvrir le menu">
          <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
            <line x1="3" y1="12" x2="21" y2="12"></line>
            <line x1="3" y1="6" x2="21" y2="6"></line>
            <line x1="3" y1="18" x2="21" y2="18"></line>
          </svg>
        </summary>
        <div class="absolute right-0 mt-2 w-56 bg-white border border-slate-200 rounded-xl shadow-xl py-2">
          {items.map((item) => (
            <a
              href={item.href}
              class:list={[
                'block px-4 py-2.5 text-sm text-slate-700',
                hoverBg,
                hoverText,
              ]}
            >
              {item.label}
            </a>
          ))}
          {cta && (
            <>
              <div class="border-t border-slate-100 my-2"></div>
              <a
                href={cta.href}
                class:list={[
                  'block px-4 py-2.5 text-sm font-semibold',
                  activeText,
                  hoverBg,
                ]}
              >
                {cta.label} →
              </a>
            </>
          )}
        </div>
      </details>
    </div>
  </div>
</header>
