---
/**
 * product-hero-split — Hero produit layout 2 colonnes.
 *
 * Variante de `article-header + figure-image` adaptée aux produits dont l'image
 * source est carrée, rectangulaire verticale ou peu allongée (cabines sauna,
 * accessoires, gourdes, objets compacts). Layout :
 *
 *   [image cadrée gauche]  |  [eyebrow + h1 + lead]
 *
 * En mobile : empilé verticalement (image au-dessus, texte en-dessous).
 *
 * Theme-aware : consomme les CSS variables suivantes (override dans global.css du site) :
 *   --bricks-color-surface      (default: #fff)
 *   --bricks-color-border       (default: #e5e7eb / slate-200)
 *   --bricks-color-text         (default: #0f172a / slate-900)
 *   --bricks-color-text-muted   (default: #475569 / slate-600)
 *   --bricks-color-text-faint   (default: #94a3b8 / slate-400)
 *   --bricks-color-accent       (default: #4338ca / indigo-700)
 *   --bricks-font-display       (default: inherit)
 *   --bricks-font-sans-tight    (default: inherit)
 *
 * Schema brique :
 *   eyebrow?, title (req), lead?, leadAsHtml?, image (req), imageAlt (req),
 *   imageCaption?, imageCredit?, imageMaxHeight? (default '420px'),
 *   amazonUrl?, amazonLabel?
 *
 * Le bouton CTA optionnel s'affiche sous le lead s'il est passé.
 */
interface Props {
  eyebrow?: string;
  title: string;
  lead?: string;
  leadAsHtml?: boolean;
  image: string;
  imageAlt: string;
  imageCaption?: string;
  imageCredit?: string;
  imageMaxHeight?: string;
  amazonUrl?: string;
  amazonLabel?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  eyebrow,
  title,
  lead,
  leadAsHtml = true,
  image,
  imageAlt,
  imageCaption,
  imageCredit,
  imageMaxHeight = '420px',
  amazonUrl,
  amazonLabel,
} = Astro.props;
---

<header class="brick-product-hero-split">
  <div class="phs-grid">
    <figure class="phs-figure">
      <img
        src={image}
        alt={imageAlt}
        loading="eager"
        decoding="async"
        fetchpriority="high"
        class="phs-img"
        style={`max-height: ${imageMaxHeight};`}
      />
      {(imageCaption || imageCredit) && (
        <figcaption class="phs-caption">
          {imageCaption}{imageCaption && imageCredit && ' '}
          {imageCredit && <span class="phs-credit">{imageCredit}</span>}
        </figcaption>
      )}
    </figure>

    <div class="phs-text">
      {eyebrow && <div class="phs-eyebrow">{eyebrow}</div>}
      <h1 class="phs-title" set:html={title} />
      {lead && (
        leadAsHtml
          ? <p class="phs-lead" set:html={lead} />
          : <p class="phs-lead">{lead}</p>
      )}
      {amazonUrl && (() => {
        const rawLabel = amazonLabel ?? 'Voir sur Amazon →';
        // Split sur " — " ou " – " : si suffix prix présent, affichage 2 lignes
        const parts = rawLabel.split(/\s+[—–]\s+/);
        const main = parts[0];
        const sub = parts.length > 1 ? parts.slice(1).join(' — ') : null;
        return (
          <a
            href={amazonUrl}
            target="_blank"
            rel="sponsored nofollow noopener"
            class="phs-cta"
          >
            <span class="phs-cta-main">{main}</span>
            {sub && <span class="phs-cta-sub">{sub}</span>}
          </a>
        );
      })()}
    </div>
  </div>
</header>

<style>
  .brick-product-hero-split {
    --_phs-surface: var(--bricks-color-surface, #ffffff);
    --_phs-border: var(--bricks-color-border, #e5e7eb);
    --_phs-text: var(--bricks-color-text, #0f172a);
    --_phs-text-muted: var(--bricks-color-text-muted, #475569);
    --_phs-text-faint: var(--bricks-color-text-faint, #94a3b8);
    --_phs-accent: var(--bricks-color-accent, #4338ca);
    --_phs-accent-text: var(--bricks-color-accent-text, #ffffff);
    --_phs-font-display: var(--bricks-font-display, inherit);
    --_phs-font-sans-tight: var(--bricks-font-sans-tight, inherit);
  }
  .phs-grid {
    display: grid;
    grid-template-columns: minmax(0, 1fr);
    gap: 2rem;
    align-items: start;
  }
  @media (min-width: 768px) {
    .phs-grid {
      grid-template-columns: minmax(280px, 0.9fr) minmax(0, 1.1fr);
      gap: 2.5rem;
      align-items: start;
    }
  }
  .phs-figure {
    margin: 0;
    background: var(--_phs-surface);
    border: 1px solid var(--_phs-border);
    border-radius: 1rem;
    overflow: hidden;
    display: flex;
    flex-direction: column;
    align-items: center;
  }
  .phs-img {
    display: block;
    width: 100%;
    height: auto;
    object-fit: contain;
    background: var(--_phs-surface);
    padding: 1rem;
    box-sizing: border-box;
  }
  .phs-caption {
    font-size: 0.75rem;
    line-height: 1.4;
    font-style: italic;
    color: var(--_phs-text-muted);
    padding: 0.5rem 0.875rem;
    background: var(--_phs-surface);
    border-top: 1px solid var(--_phs-border);
    width: 100%;
    text-align: center;
  }
  .phs-credit {
    color: var(--_phs-text-faint);
  }
  .phs-text {
    display: flex;
    flex-direction: column;
    gap: 1rem;
  }
  .phs-eyebrow {
    font-family: var(--_phs-font-sans-tight);
    font-size: 0.75rem;
    font-weight: 700;
    text-transform: uppercase;
    letter-spacing: 0.12em;
    color: var(--_phs-accent);
  }
  .phs-title {
    font-family: var(--_phs-font-display);
    font-size: clamp(1.875rem, 3vw, 2.5rem);
    font-weight: 800;
    line-height: 1.15;
    color: var(--_phs-text);
    margin: 0;
  }
  .phs-lead {
    font-size: 1.0625rem;
    line-height: 1.6;
    color: var(--_phs-text-muted);
    margin: 0;
  }
  .phs-cta {
    align-self: flex-start;
    margin-top: 0.5rem;
    background: var(--_phs-accent);
    color: var(--_phs-accent-text);
    font-weight: 700;
    padding: 0.75rem 1.25rem;
    border-radius: 0.5rem;
    text-decoration: none;
    transition: filter 0.15s ease;
    display: inline-flex;
    flex-direction: column;
    align-items: center;
    text-align: center;
    line-height: 1.25;
  }
  .phs-cta-main {
    display: block;
    font-size: 1rem;
  }
  .phs-cta-sub {
    display: block;
    font-size: 0.875rem;
    font-weight: 600;
    opacity: 0.92;
    margin-top: 0.2rem;
  }
  .phs-cta:hover {
    filter: brightness(0.92);
  }
</style>
