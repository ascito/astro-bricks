---
/**
 * PersonaCard — Carte cliquable pour un profil utilisateur (persona).
 *
 * Rendu : icône + eyebrow + titre + description + liste produits cités + CTA.
 * Bordure colorée selon la palette du persona (mappage Tailwind interne).
 *
 * Usage simple (passe l'objet persona) :
 * ```astro
 * import PersonaCard from 'astro-bricks/bricks/business/PersonaCard.astro';
 * import personasData from '../../data/personas.json';
 *
 * <section style="display:grid; grid-template-columns:repeat(auto-fit, minmax(300px, 1fr)); gap:1.25rem;">
 *   {personasData.personas.map(p => <PersonaCard persona={p} />)}
 * </section>
 * ```
 *
 * Usage compact (variante home, sans `pianos` ni CTA visible) :
 * ```astro
 * <PersonaCard persona={p} compact ctaLabel={null} />
 * ```
 *
 * Le mapping `color → classes Tailwind` est centralisé en haut du composant.
 * Si tu ajoutes une couleur dans `personaColorSchema`, ajoute aussi son mapping ici.
 */
interface PersonaInput {
  slug: string;
  href: string;
  icon: string;
  color: string;
  eyebrow: string;
  title: string;
  shortDesc: string;
  longDesc: string;
  pianos: string;
  showOnHome?: boolean;
}

interface Props {
  /** Objet persona (cf. `personaSchema` dans astro-bricks/schemas). */
  persona: PersonaInput;
  /** Mode compact : utilise `shortDesc` au lieu de `longDesc`, masque `pianos`. Défaut: false. */
  compact?: boolean;
  /** Label du CTA. `null` pour masquer. Défaut: 'Voir nos recommandations →'. */
  ctaLabel?: string | null;
  /** Préfixe affiché avant la liste pianos. Défaut: 'Pianos cités :'. */
  productsLabel?: string;
  /** Classes additionnelles sur la racine `<a>`. */
  class?: string;
}

const {
  persona,
  compact = false,
  ctaLabel = 'Voir nos recommandations →',
  productsLabel = 'Pianos cités :',
  class: extraClass = '',
} = Astro.props;

// ─── Mapping couleur sémantique → classes Tailwind ───
// Ajoute ici les mappings pour toute nouvelle couleur de personaColorSchema.
const COLOR_MAP: Record<string, { border: string; eyebrow: string; hoverTitle: string }> = {
  indigo:  { border: 'border-indigo-300 hover:border-indigo-500',   eyebrow: 'text-indigo-700',   hoverTitle: 'group-hover:text-indigo-700' },
  rose:    { border: 'border-rose-300 hover:border-rose-500',       eyebrow: 'text-rose-700',     hoverTitle: 'group-hover:text-rose-700' },
  amber:   { border: 'border-amber-300 hover:border-amber-500',     eyebrow: 'text-amber-700',    hoverTitle: 'group-hover:text-amber-700' },
  emerald: { border: 'border-emerald-300 hover:border-emerald-500', eyebrow: 'text-emerald-700',  hoverTitle: 'group-hover:text-emerald-700' },
  violet:  { border: 'border-violet-300 hover:border-violet-500',   eyebrow: 'text-violet-700',   hoverTitle: 'group-hover:text-violet-700' },
  slate:   { border: 'border-slate-300 hover:border-slate-500',     eyebrow: 'text-slate-700',    hoverTitle: 'group-hover:text-slate-700' },
  teal:    { border: 'border-teal-300 hover:border-teal-500',       eyebrow: 'text-teal-700',     hoverTitle: 'group-hover:text-teal-700' },
  cyan:    { border: 'border-cyan-300 hover:border-cyan-500',       eyebrow: 'text-cyan-700',     hoverTitle: 'group-hover:text-cyan-700' },
  sky:     { border: 'border-sky-300 hover:border-sky-500',         eyebrow: 'text-sky-700',      hoverTitle: 'group-hover:text-sky-700' },
  fuchsia: { border: 'border-fuchsia-300 hover:border-fuchsia-500', eyebrow: 'text-fuchsia-700',  hoverTitle: 'group-hover:text-fuchsia-700' },
};
const palette = COLOR_MAP[persona.color] ?? COLOR_MAP.slate;

const desc = compact ? persona.shortDesc : persona.longDesc;
---

<a
  href={persona.href}
  class={`group bg-white border-2 ${palette.border} rounded-2xl p-6 transition-colors ${extraClass}`}
  style="display:flex; flex-direction:column; gap:0.75rem;"
  data-persona-slug={persona.slug}
>
  <div class="text-4xl" aria-hidden="true">{persona.icon}</div>
  <div class={`text-xs font-bold uppercase tracking-wider ${palette.eyebrow}`}>{persona.eyebrow}</div>
  <h2 class={`font-display font-bold text-2xl text-slate-900 ${palette.hoverTitle}`}>{persona.title}</h2>
  <p class="text-slate-700 text-sm leading-relaxed">{desc}</p>
  {!compact && persona.pianos && (
    <div class="text-xs font-semibold text-slate-500 italic">{productsLabel} {persona.pianos}</div>
  )}
  {ctaLabel && (
    <span class={`mt-auto text-sm font-bold ${palette.eyebrow}`}>{ctaLabel}</span>
  )}
</a>
