---
/**
 * Faq — Section FAQ sémantique (titre H2 + accordéon).
 *
 * Compose `Accordion` (déjà dans composites/) avec :
 *  - Un wrapper `<section>` accessible (aria-labelledby)
 *  - Un titre H2 personnalisable
 *  - Spacing éditorial (mt-14)
 *
 * Pour générer aussi le JSON-LD FAQPage, utiliser <JsonLdFaq /> à côté.
 */
import Accordion from '../composites/Accordion.astro';

interface FaqItem {
  question: string;
  answer: string; // HTML autorisé
}

interface Props {
  items: FaqItem[];
  title?: string;
  /** ID utilisé pour l'aria-labelledby ET pour grouper les <details>. */
  id?: string;
  /** Niveau du titre. Défaut : 2. */
  level?: 2 | 3;
  /** Classe Tailwind pour le titre. Défaut : `text-slate-900`. */
  titleClass?: string;
  /** Variante de l'accordion (cf Accordion.astro). */
  variant?: 'default' | 'bordered' | 'separated';
  /** Autoriser plusieurs items ouverts simultanément. */
  allowMultiple?: boolean;
  /** Classes wrapper additionnelles. */
  class?: string;
}

const {
  items,
  title = 'Questions fréquentes',
  id = 'faq',
  level = 2,
  titleClass = 'text-slate-900',
  variant = 'default',
  allowMultiple = false,
  class: customClass = '',
} = Astro.props;

const TitleTag = `h${level}` as 'h2' | 'h3';
---

<section
  aria-labelledby={`${id}-title`}
  data-brick="faq"
  class:list={['mt-14', customClass]}
>
  <TitleTag
    id={`${id}-title`}
    class:list={['mb-6 font-display text-3xl', titleClass]}
  >
    {title}
  </TitleTag>

  <Accordion
    items={items}
    variant={variant}
    allowMultiple={allowMultiple}
    _brickId={id}
    _brickType="faq"
  />
</section>
