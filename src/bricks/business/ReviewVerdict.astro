---
/**
 * review-verdict — Encart "Verdict en 30 secondes" pour les pages avis
 * Schema : title, stats[]{value, label, suffix?}, pros[], cons[], cta{label, href}
 *
 * Renders : aside ambre avec 4 stats en grid 2×2, deux colonnes ✓/✗, CTA orange.
 */
interface Stat {
  value: string | number;
  label: string;
  suffix?: string;
}
interface Cta {
  label: string;
  href: string;
}
interface Props {
  title?: string;
  stats?: Stat[];
  pros?: string[];
  cons?: string[];
  cta?: Cta;
  disclosure?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  title = 'Verdict en 30 secondes',
  stats = [],
  pros = [],
  cons = [],
  cta,
  disclosure = 'Lien affilié — PianoGuide perçoit une commission sans surcoût pour vous.',
} = Astro.props;
---
<aside class="bg-amber-50 border-l-4 border-amber-400 p-6 rounded-r-lg">
  <h2 class="font-sans font-extrabold tracking-tight text-lg text-slate-900 mb-3">{title}</h2>
  {stats.length > 0 && (
    <div class="grid grid-cols-2 sm:grid-cols-4 gap-4 mb-5 text-sm">
      {stats.map((s) => (
        <div>
          <p class="text-slate-900 font-bold text-2xl leading-tight mb-1">
            {s.value}
            {s.suffix && <span class="text-slate-500 text-base font-normal">{s.suffix}</span>}
          </p>
          <p class="text-[11px] uppercase tracking-wider text-slate-500 leading-tight">{s.label}</p>
        </div>
      ))}
    </div>
  )}
  {(pros.length > 0 || cons.length > 0) && (
    <ul class="text-sm text-slate-700 space-y-1.5 mb-4 list-none">
      {pros.map((p) => (
        <li class="flex gap-2.5 items-start">
          <svg width="14" height="14" viewBox="0 0 20 20" class="text-emerald-600 flex-shrink-0 mt-1" aria-hidden="true">
            <path d="M16.7 5.3a1 1 0 010 1.4l-7 7a1 1 0 01-1.4 0l-3-3a1 1 0 011.4-1.4L9 11.6l6.3-6.3a1 1 0 011.4 0z" fill="currentColor"/>
          </svg>
          <span set:html={p} />
        </li>
      ))}
      {cons.map((c) => (
        <li class="flex gap-2.5 items-start">
          <svg width="14" height="14" viewBox="0 0 20 20" class="text-amber-600 flex-shrink-0 mt-1" aria-hidden="true">
            <path d="M10 2a1 1 0 01.87.5l8 14A1 1 0 0118 18H2a1 1 0 01-.87-1.5l8-14A1 1 0 0110 2zm0 5a1 1 0 00-1 1v4a1 1 0 102 0V8a1 1 0 00-1-1zm0 8a1 1 0 100-2 1 1 0 000 2z" fill="currentColor"/>
          </svg>
          <span set:html={c} />
        </li>
      ))}
    </ul>
  )}
  {cta && (
    <div class="border-t border-amber-300 mt-6 pt-6 pb-2 px-2 text-center">
      <style>
        /* Default = orange-500 Tailwind (legacy). Sites override via
           --bricks-color-accent dans leur global.css (cf app consommatrice). */
        .rv-cta {
          background: var(--bricks-color-accent, #f97316);
          color: var(--bricks-color-accent-text, #ffffff);
        }
        .rv-cta:hover {
          filter: brightness(0.92);
        }
      </style>
      {(() => {
        const parts = (cta.label || '').split(/\s+[—–]\s+/);
        const main = parts[0];
        const sub = parts.length > 1 ? parts.slice(1).join(' — ') : null;
        return (
          <a
            href={cta.href}
            target="_blank"
            rel="nofollow sponsored noopener"
            class="rv-cta inline-flex items-center gap-3 font-bold rounded-full px-8 py-3 transition shadow-md"
          >
            <span class="flex flex-col items-start leading-tight">
              <span class="text-base">{main}</span>
              {sub && <span class="text-xs font-semibold opacity-90 mt-0.5">{sub}</span>}
            </span>
            <svg width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" class="flex-shrink-0">
              <line x1="7" y1="17" x2="17" y2="7" />
              <polyline points="7 7 17 7 17 17" />
            </svg>
          </a>
        );
      })()}
      {disclosure && <p class="text-xs text-slate-600 mt-4">{disclosure}</p>}
    </div>
  )}
</aside>
