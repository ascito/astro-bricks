---
/**
 * progress-bar — Barre de progression avec pourcentage.
 *
 * Schema catalog : {
 *   value?, max?, label?, showValue?, valuePosition?, valueFormat?,
 *   variant?, color?, size?, rounded?, indeterminate?
 * }
 *
 * Fonctionnement : div + width (le `<progress>` natif ne permet pas le rayage ni les
 * couleurs thémées de façon fiable cross-browser). La piste porte `role="progressbar"`
 * + `aria-valuenow/min/max`. `indeterminate` masque la valeur et anime une barre
 * coulissante. `striped`/`animated` ajoutent un motif diagonal (animé). La valeur est
 * formatée en pourcentage, valeur brute, ou fraction selon `valueFormat`, et placée
 * à l'intérieur, à l'extérieur (sous la barre), ou au-dessus selon `valuePosition`.
 *
 * Théming : consomme `--bricks-color-accent` (color=primary), `--bricks-color-secondary`
 * et `--bricks-color-border` (piste) avec fallbacks ; les autres couleurs sont des
 * teintes sémantiques fixes.
 */
interface Props {
  /** Valeur actuelle (0-100 par défaut). Défaut : 0. */
  value?: number;
  /** Valeur maximum. Défaut : 100. */
  max?: number;
  /** Label affiché. */
  label?: string;
  /** Afficher la valeur/pourcentage. Défaut : false. */
  showValue?: boolean;
  /** Position de la valeur. Défaut : "outside". */
  valuePosition?: 'inside' | 'outside' | 'top';
  /** Format : "75%", "75", "75/100". Défaut : "percent". */
  valueFormat?: 'percent' | 'value' | 'fraction';
  /** Style de la barre. Défaut : "default". */
  variant?: 'default' | 'striped' | 'animated';
  /** Couleur. Défaut : "primary". */
  color?: 'primary' | 'success' | 'warning' | 'danger' | 'info' | 'secondary';
  /** Épaisseur. Défaut : "md". */
  size?: 'xs' | 'sm' | 'md' | 'lg';
  /** Coins en pilule. Défaut : true. */
  rounded?: boolean;
  /** Mode indéterminé (chargement sans valeur). Défaut : false. */
  indeterminate?: boolean;
  _brickId?: string;
  _brickType?: string;
}

const {
  value = 0,
  max = 100,
  label,
  showValue = false,
  valuePosition = 'outside',
  valueFormat = 'percent',
  variant = 'default',
  color = 'primary',
  size = 'md',
  rounded = true,
  indeterminate = false,
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const clamped = Math.min(Math.max(value, 0), max);
const pct = max > 0 ? Math.round((clamped / max) * 100) : 0;

const fillColor = {
  primary: 'var(--bricks-color-accent,#2563eb)',
  secondary: 'var(--bricks-color-secondary,#64748b)',
  success: '#16a34a',
  warning: '#d97706',
  danger: '#dc2626',
  info: '#0891b2',
}[color];

const heightClass = { xs: 'h-1', sm: 'h-2', md: 'h-3', lg: 'h-5' }[size];
const radiusClass = rounded ? 'rounded-full' : 'rounded';

const formatted =
  valueFormat === 'percent'
    ? `${pct}%`
    : valueFormat === 'fraction'
      ? `${clamped}/${max}`
      : `${clamped}`;

const labelClass =
  'font-sans font-extrabold tracking-tight text-sm text-[var(--bricks-color-text,#0f172a)]';
const valueClass = 'text-sm text-[var(--bricks-color-text-muted,#475569)]';
---

<div class="mb-6" {...rest}>
  {(label || (showValue && valuePosition === 'top')) && (
    <div class="mb-1.5 flex items-center justify-between gap-3">
      {label && <span class={labelClass}>{label}</span>}
      {showValue && valuePosition === 'top' && !indeterminate && (
        <span class={valueClass}>{formatted}</span>
      )}
    </div>
  )}

  <div
    role="progressbar"
    aria-valuemin={0}
    aria-valuemax={max}
    aria-valuenow={indeterminate ? undefined : clamped}
    aria-label={label}
    class:list={[
      'relative w-full overflow-hidden',
      heightClass,
      radiusClass,
      'bg-[var(--bricks-color-border,#e2e8f0)]',
    ]}
  >
    <div
      class:list={[
        'progress-fill h-full',
        radiusClass,
        variant === 'striped' || variant === 'animated' ? 'progress-striped' : '',
        variant === 'animated' ? 'progress-animated' : '',
        indeterminate ? 'progress-indeterminate' : 'transition-[width] duration-500',
        'flex items-center justify-end',
      ]}
      style={`width:${indeterminate ? '40%' : pct + '%'};background-color:${fillColor}`}
    >
      {showValue && valuePosition === 'inside' && !indeterminate && size === 'lg' && (
        <span class="px-2 text-[11px] font-semibold text-white">{formatted}</span>
      )}
    </div>
  </div>

  {showValue && valuePosition === 'outside' && !indeterminate && (
    <div class="mt-1 text-right">
      <span class={valueClass}>{formatted}</span>
    </div>
  )}
</div>

<style>
  .progress-striped {
    background-image: linear-gradient(
      45deg,
      rgba(255, 255, 255, 0.2) 25%,
      transparent 25%,
      transparent 50%,
      rgba(255, 255, 255, 0.2) 50%,
      rgba(255, 255, 255, 0.2) 75%,
      transparent 75%,
      transparent
    );
    background-size: 1rem 1rem;
  }
  .progress-animated {
    animation: progress-stripes 1s linear infinite;
  }
  .progress-indeterminate {
    position: absolute;
    left: 0;
    animation: progress-indeterminate 1.4s ease-in-out infinite;
  }
  @keyframes progress-stripes {
    from { background-position: 1rem 0; }
    to { background-position: 0 0; }
  }
  @keyframes progress-indeterminate {
    0% { left: -40%; }
    100% { left: 100%; }
  }
  @media (prefers-reduced-motion: reduce) {
    .progress-animated,
    .progress-indeterminate { animation: none; }
  }
</style>
