---
/**
 * link — Lien hypertexte
 * Schema catalog : { label, href, target?, rel?, variant? }
 */
interface Props {
  label: string;
  href: string;
  target?: '_blank' | '_self';
  rel?: string;
  variant?: 'default' | 'subtle' | 'underline';
  _brickId?: string;
  _brickType?: string;
}

const { label, href, target, rel, variant = 'default', _brickId, _brickType, ...rest } = Astro.props;
const variantClass = {
  default: 'text-blue-700 hover:text-blue-900 underline underline-offset-2',
  subtle: 'text-gray-700 hover:text-gray-900',
  underline: 'text-blue-700 underline decoration-2 underline-offset-2 hover:text-blue-900',
}[variant];

// Sécurité : ajouter automatiquement noopener si target=_blank et pas de rel
const safeRel = target === '_blank' && !rel ? 'noopener noreferrer' : rel;
---
<a href={href} target={target} rel={safeRel} class={variantClass} {...rest}>{label}</a>
