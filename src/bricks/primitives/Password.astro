---
/**
 * password — Champ mot de passe avec toggle visibilité.
 *
 * Schema catalog : {
 *   name?, label?, placeholder?, value?, bind?, showToggle?, showStrength?,
 *   strengthLabels?, minLength?, maxLength?, required?, disabled?, error?,
 *   hint?, size?, variant?, autocomplete?
 * }
 *
 * Contrôle de formulaire HTML natif (<input type="password">). Un <script> client
 * (rendu si showToggle ou showStrength) gère le basculement de visibilité (bouton
 * œil) et l'indicateur de force, avec ré-init sur astro:page-load + guard
 * dataset.initialized. `bind` est exposé via data-value.
 *
 * Théming : `--bricks-color-border`, `--bricks-color-text`, `--bricks-color-surface`,
 * `--bricks-color-accent` (focus) avec fallbacks.
 */
interface StrengthLabels {
  weak?: string;
  medium?: string;
  strong?: string;
}

interface Props {
  /** Nom du champ. Défaut : "password". */
  name?: string;
  /** Label du champ. */
  label?: string;
  /** Placeholder. Défaut : "••••••••". */
  placeholder?: string;
  /** Valeur initiale. */
  value?: string;
  /** Chemin binding. Génère data-value. */
  bind?: string;
  /** Afficher le bouton pour voir le mot de passe. Défaut : true. */
  showToggle?: boolean;
  /** Afficher l'indicateur de force. Défaut : false. */
  showStrength?: boolean;
  /** Labels personnalisés pour les niveaux de force. */
  strengthLabels?: StrengthLabels;
  /** Longueur minimale requise. */
  minLength?: number;
  /** Longueur maximale. */
  maxLength?: number;
  /** Champ requis. Défaut : false. */
  required?: boolean;
  /** Désactiver le champ. Défaut : false. */
  disabled?: boolean;
  /** Message d'erreur. */
  error?: string;
  /** Texte d'aide. */
  hint?: string;
  /** Taille. Défaut : "md". */
  size?: 'sm' | 'md' | 'lg';
  /** Style visuel. Défaut : "default". */
  variant?: 'default' | 'filled' | 'outlined';
  /** Autocomplete. Défaut : "current-password". */
  autocomplete?: 'current-password' | 'new-password' | 'off';
  _brickId?: string;
  _brickType?: string;
}

const {
  name = 'password',
  label,
  placeholder = '••••••••',
  value,
  bind,
  showToggle = true,
  showStrength = false,
  strengthLabels,
  minLength,
  maxLength,
  required = false,
  disabled = false,
  error,
  hint,
  size = 'md',
  variant = 'default',
  autocomplete = 'current-password',
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const fieldId = `password-${_brickId ?? Math.random().toString(36).slice(2, 8)}`;
const needsScript = showToggle || showStrength;

const labels: Required<StrengthLabels> = {
  weak: strengthLabels?.weak ?? 'Faible',
  medium: strengthLabels?.medium ?? 'Moyen',
  strong: strengthLabels?.strong ?? 'Fort',
};

const sizeClass = {
  sm: 'text-sm py-1.5 pl-2.5',
  md: 'text-sm py-2 pl-3',
  lg: 'text-base py-2.5 pl-3.5',
}[size];

const variantClass: Record<NonNullable<Props['variant']>, string> = {
  default: 'border bg-[var(--bricks-color-surface,#ffffff)]',
  filled: 'border border-transparent bg-[var(--bricks-color-surface-muted,#f1f5f9)]',
  outlined: 'border-2 bg-transparent',
};

const borderColor = error
  ? 'border-red-500'
  : 'border-[var(--bricks-color-border,#e2e8f0)]';

const textSize = { sm: 'text-sm', md: 'text-sm', lg: 'text-base' }[size];
---
<div
  class="mb-6"
  data-password
  data-show-strength={showStrength ? 'true' : 'false'}
  data-label-weak={labels.weak}
  data-label-medium={labels.medium}
  data-label-strong={labels.strong}
  {...rest}
>
  {label && (
    <label for={fieldId} class:list={['mb-1.5 block', textSize, 'text-[var(--bricks-color-text,#0f172a)]']}>
      {label}
    </label>
  )}
  <div class="relative">
    <input
      id={fieldId}
      type="password"
      name={name}
      placeholder={placeholder}
      value={value}
      minlength={minLength}
      maxlength={maxLength}
      required={required}
      disabled={disabled}
      autocomplete={autocomplete}
      data-value={bind ?? undefined}
      data-password-input
      aria-invalid={error ? 'true' : undefined}
      aria-describedby={error ? `${fieldId}-error` : hint ? `${fieldId}-hint` : undefined}
      class:list={[
        'block w-full rounded-md text-[var(--bricks-color-text,#0f172a)]',
        showToggle ? 'pr-10' : 'pr-3',
        'placeholder:text-[var(--bricks-color-text-faint,#94a3b8)]',
        'focus:outline-none focus-visible:ring-2 focus-visible:ring-[var(--bricks-color-accent,#2563eb)]',
        'disabled:cursor-not-allowed disabled:opacity-60',
        sizeClass,
        variantClass[variant],
        borderColor,
      ]}
    />
    {showToggle && (
      <button
        type="button"
        data-password-toggle
        aria-label="Afficher le mot de passe"
        aria-pressed="false"
        class="absolute inset-y-0 right-0 flex items-center px-3 text-[var(--bricks-color-text-muted,#475569)] hover:text-[var(--bricks-color-text,#0f172a)] focus-visible:outline-2 focus-visible:outline-offset-2 focus-visible:outline-[var(--bricks-color-accent,#2563eb)]"
      >
        <svg data-icon-show width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M2 12s3.5-7 10-7 10 7 10 7-3.5 7-10 7-10-7-10-7z" />
          <circle cx="12" cy="12" r="3" />
        </svg>
        <svg data-icon-hide hidden width="18" height="18" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <path d="M17.94 17.94A10.07 10.07 0 0 1 12 20c-7 0-10-8-10-8a18.45 18.45 0 0 1 5.06-5.94M9.9 4.24A9.12 9.12 0 0 1 12 4c7 0 10 8 10 8a18.5 18.5 0 0 1-2.16 3.19" />
          <path d="m1 1 22 22" />
        </svg>
      </button>
    )}
  </div>
  {showStrength && (
    <div class="mt-2" data-strength hidden>
      <div class="h-1.5 w-full overflow-hidden rounded-full bg-[var(--bricks-color-border,#e2e8f0)]">
        <div class="h-full w-0 rounded-full transition-all duration-200" data-strength-bar></div>
      </div>
      <p class="mt-1 text-xs" data-strength-label></p>
    </div>
  )}
  {hint && !error && (
    <p id={`${fieldId}-hint`} class="mt-1 text-xs text-[var(--bricks-color-text-muted,#475569)]">{hint}</p>
  )}
  {error && (
    <p id={`${fieldId}-error`} class="mt-1 text-xs text-red-600">{error}</p>
  )}
</div>

{needsScript && (
  <script>
    function setupPassword(root: HTMLElement) {
      if (root.dataset.initialized === 'true') return;
      root.dataset.initialized = 'true';

      const input = root.querySelector<HTMLInputElement>('[data-password-input]');
      if (!input) return;

      const toggle = root.querySelector<HTMLButtonElement>('[data-password-toggle]');
      if (toggle) {
        const iconShow = toggle.querySelector<SVGElement>('[data-icon-show]');
        const iconHide = toggle.querySelector<SVGElement>('[data-icon-hide]');
        toggle.addEventListener('click', () => {
          const reveal = input.type === 'password';
          input.type = reveal ? 'text' : 'password';
          toggle.setAttribute('aria-pressed', reveal ? 'true' : 'false');
          toggle.setAttribute(
            'aria-label',
            reveal ? 'Masquer le mot de passe' : 'Afficher le mot de passe'
          );
          if (iconShow) iconShow.hidden = reveal;
          if (iconHide) iconHide.hidden = !reveal;
        });
      }

      if (root.dataset.showStrength === 'true') {
        const wrap = root.querySelector<HTMLElement>('[data-strength]');
        const bar = root.querySelector<HTMLElement>('[data-strength-bar]');
        const label = root.querySelector<HTMLElement>('[data-strength-label]');
        const labels = {
          weak: root.dataset.labelWeak || 'Faible',
          medium: root.dataset.labelMedium || 'Moyen',
          strong: root.dataset.labelStrong || 'Fort',
        };

        const score = (pwd: string): number => {
          let s = 0;
          if (pwd.length >= 8) s++;
          if (/[a-z]/.test(pwd) && /[A-Z]/.test(pwd)) s++;
          if (/\d/.test(pwd)) s++;
          if (/[^A-Za-z0-9]/.test(pwd)) s++;
          return s;
        };

        const levels = [
          { width: '33%', color: '#dc2626', text: labels.weak },
          { width: '66%', color: '#d97706', text: labels.medium },
          { width: '100%', color: '#16a34a', text: labels.strong },
        ];

        const render = () => {
          const len = input.value.length;
          if (wrap) wrap.hidden = len === 0;
          if (len === 0) return;
          const s = score(input.value);
          const idx = s <= 1 ? 0 : s === 2 ? 1 : 2;
          const lvl = levels[idx];
          if (bar) {
            bar.style.width = lvl.width;
            bar.style.background = lvl.color;
          }
          if (label) {
            label.textContent = lvl.text;
            label.style.color = lvl.color;
          }
        };

        input.addEventListener('input', render);
        render();
      }
    }

    function initAllPassword() {
      document
        .querySelectorAll<HTMLElement>('[data-password]')
        .forEach((el) => setupPassword(el));
    }

    initAllPassword();
    document.addEventListener('astro:page-load', initAllPassword);
  </script>
)}
