---
/**
 * footer — Pied de page avec liens et copyright.
 *
 * Schema catalog : {
 *   logo? {text?, src?, href?}, description?, columns? [{title?, links:[{label, href}]}],
 *   social? [{platform/label, href, icon?}], copyright?, variant?, size?, className?
 * }
 *
 * Structure : <footer> (pas de marge propre, élément de structure de page).
 * Théming : consomme les variables `--bricks-color-*` (surface/border/text/accent) avec fallbacks.
 */
interface LogoInput {
  text?: string;
  src?: string;
  href?: string;
}
interface FooterLink {
  label: string;
  href: string;
}
interface FooterColumn {
  title?: string;
  links?: FooterLink[];
}
interface SocialLink {
  platform?: string;
  label?: string;
  href: string;
  icon?: string;
}

interface Props {
  /** Logo (texte et/ou image + lien). */
  logo?: LogoInput;
  /** Texte de description sous le logo. */
  description?: string;
  /** Colonnes de liens. */
  columns?: FooterColumn[];
  /** Liens sociaux. */
  social?: SocialLink[];
  /** Texte de copyright. */
  copyright?: string;
  /** Style. Défaut : 'light'. */
  variant?: 'light' | 'dark' | 'primary';
  /** Taille (densité du padding). Défaut : 'md'. */
  size?: 'sm' | 'md' | 'lg';
  /** Classes additionnelles. */
  className?: string;
  _brickId?: string;
  _brickType?: string;
}

const {
  logo,
  description = '',
  columns = [],
  social = [],
  copyright = '',
  variant = 'light',
  size = 'md',
  className = '',
  _brickId,
  _brickType,
  ...rest
} = Astro.props;

const isDark = variant === 'dark' || variant === 'primary';

const VARIANT_BG: Record<string, string> = {
  light: 'bg-[var(--bricks-color-surface,#ffffff)] border-t border-[var(--bricks-color-border,#e2e8f0)]',
  dark: 'bg-[var(--bricks-color-text,#0f172a)]',
  primary: 'bg-[var(--bricks-color-accent,#2563eb)]',
};
const PAD: Record<string, string> = { sm: 'py-8', md: 'py-12', lg: 'py-16' };

const textMain = isDark ? 'text-white' : 'text-[var(--bricks-color-text,#0f172a)]';
const textMuted = isDark ? 'text-white/70' : 'text-[var(--bricks-color-text-muted,#475569)]';
const linkColor = isDark ? 'text-white/70 hover:text-white' : 'text-[var(--bricks-color-text-muted,#475569)] hover:text-[var(--bricks-color-text,#0f172a)]';
const borderColor = isDark ? 'border-white/15' : 'border-[var(--bricks-color-border,#e2e8f0)]';

const socialLinks = social.filter((s) => s && s.href);
---
<footer class:list={[VARIANT_BG[variant], className]} {...rest}>
  <div class:list={['mx-auto max-w-7xl px-4', PAD[size]]}>
    <div class="grid grid-cols-1 gap-8 sm:grid-cols-2 lg:grid-cols-4">
      <div class="lg:col-span-1">
        <a href={logo?.href ?? '/'} class:list={['inline-flex items-center gap-2 font-sans font-extrabold tracking-tight text-lg', textMain]}>
          {logo?.src && <img src={logo.src} alt={logo?.text ?? 'Logo'} class="h-8 w-auto" height="32" />}
          {logo?.text && <span>{logo.text}</span>}
        </a>
        {description && <p class:list={['mt-3 max-w-xs text-sm leading-relaxed', textMuted]}>{description}</p>}
        {socialLinks.length > 0 && (
          <div class="mt-4 flex flex-wrap gap-3 text-sm">
            {socialLinks.map((s) => (
              <a href={s.href} target="_blank" rel="noopener" class:list={['font-semibold transition-colors', linkColor]}>
                {s.icon && <span aria-hidden="true">{s.icon} </span>}{s.platform ?? s.label ?? s.href}
              </a>
            ))}
          </div>
        )}
      </div>

      {columns.map((col) => (
        <nav aria-label={col.title}>
          {col.title && (
            <h3 class:list={['mb-3 font-sans font-extrabold tracking-tight text-sm uppercase', textMain]}>
              {col.title}
            </h3>
          )}
          <ul class="space-y-2 text-sm">
            {(col.links ?? []).map((link) => (
              <li>
                <a href={link.href} class:list={['transition-colors', linkColor]}>{link.label}</a>
              </li>
            ))}
          </ul>
        </nav>
      ))}
    </div>

    {copyright && (
      <div class:list={['mt-8 border-t pt-6 text-sm', borderColor, textMuted]}>
        {copyright}
      </div>
    )}
  </div>
</footer>
